<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="300"
  d:DesignHeight="240"
  x:Class="MissionPlannerAvalonia.Views.LinkStatsWindow"
  x:DataType="vm:LinkStatsViewModel"
  Background="{DynamicResource MpControlBg}"
  Width="300"
  Height="250"
  CanResize="False"
  WindowStartupLocation="CenterOwner"
  Title="Link Stats"
>
  <Grid Margin="14" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*"
        ColumnDefinitions="Auto,*" ColumnSpacing="12">
    <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" Text="Bytes received" />
    <TextBlock Grid.Row="0" Grid.Column="1" Classes="val" Text="{Binding RxRate}" />

    <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" Text="Bytes sent" />
    <TextBlock Grid.Row="1" Grid.Column="1" Classes="val" Text="{Binding TxRate}" />

    <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" Text="Packets" />
    <TextBlock Grid.Row="2" Grid.Column="1" Classes="val" Text="{Binding PacketCount}" />

    <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" Text="Packets lost" />
    <TextBlock Grid.Row="3" Grid.Column="1" Classes="val" Text="{Binding PacketsLostText}" />

    <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" Text="Link quality" />
    <TextBlock Grid.Row="4" Grid.Column="1" Classes="val" Text="{Binding LinkQuality}" />

    <TextBlock Grid.Row="5" Grid.Column="0" Classes="lbl" Text="Time connected" />
    <TextBlock Grid.Row="5" Grid.Column="1" Classes="val" Text="{Binding TimeConnected}" />

    <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0"
               Foreground="#9AD" Text="{Binding Status}" />
  </Grid>

  <Window.Styles>
    <Style Selector="TextBlock.val">
      <Setter Property="Foreground" Value="WhiteSmoke" />
      <Setter Property="FontFamily" Value="Courier New,monospace" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="Margin" Value="0,4" />
    </Style>
  </Window.Styles>
</Window>
