<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  mc:Ignorable="d"
  d:DesignWidth="460"
  d:DesignHeight="340"
  x:Class="MissionPlannerAvalonia.Views.SerialOutputNMEAView"
  x:DataType="vm:SerialOutputNMEAViewModel"
  Background="{DynamicResource MpControlBg}"
>
  <StackPanel Margin="16" Spacing="10">
    <TextBlock Text="NMEA Output" FontSize="16" Foreground="#DDD" />
    <TextBlock
      Foreground="#AAA"
      TextWrapping="Wrap"
      Text="Emits NMEA-0183 GGA/GLL/HDG/VTG/RMC sentences from the live vehicle position to the selected port."
    />

    <Grid ColumnDefinitions="110,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Port" Foreground="#DDD" VerticalAlignment="Center" />
      <ComboBox
        Grid.Row="0"
        Grid.Column="1"
        HorizontalAlignment="Stretch"
        ItemsSource="{Binding Ports}"
        SelectedItem="{Binding SelectedPort}"
      />
      <Button Grid.Row="0" Grid.Column="2" Content="Refresh" Command="{Binding RefreshPortsCommand}" Margin="6,0,0,0" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Baud" Foreground="#DDD" VerticalAlignment="Center" />
      <ComboBox
        Grid.Row="1"
        Grid.Column="1"
        HorizontalAlignment="Stretch"
        ItemsSource="{Binding Bauds}"
        SelectedItem="{Binding SelectedBaud}"
      />

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Update rate (Hz)" Foreground="#DDD" VerticalAlignment="Center" />
      <ComboBox
        Grid.Row="2"
        Grid.Column="1"
        HorizontalAlignment="Stretch"
        ItemsSource="{Binding Rates}"
        SelectedItem="{Binding UpdateRateHz}"
      />
    </Grid>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding ConnectButtonText}" Command="{Binding ToggleConnectCommand}" MinWidth="90" />
    </StackPanel>

    <Border Background="{DynamicResource MpInputBg}" CornerRadius="4" Padding="10">
      <StackPanel Spacing="4">
        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource MpAccentBrush}" TextWrapping="Wrap" />
        <TextBlock Text="Last sentence:" Foreground="#AAA" />
        <TextBlock Text="{Binding LastSentence}" Foreground="#DDD" FontFamily="Consolas,monospace" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
