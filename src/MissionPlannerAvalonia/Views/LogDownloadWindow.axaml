<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="520"
  d:DesignHeight="420"
  x:Class="MissionPlannerAvalonia.Views.LogDownloadWindow"
  x:DataType="vm:LogDownloadViewModel"
  Background="#434445"
  Width="540"
  Height="440"
  WindowStartupLocation="CenterOwner"
  Title="Download Logs (MAVLink)"
>
  <Grid Margin="12" RowDefinitions="Auto,*,Auto,Auto">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Content="Refresh List" Command="{Binding RefreshCommand}"
              IsEnabled="{Binding !IsBusy}" />
      <Button Content="Download Selected" Command="{Binding DownloadCommand}"
              IsEnabled="{Binding !IsBusy}" />
    </StackPanel>

    <Border Grid.Row="1" BorderBrush="#666" BorderThickness="1">
      <DataGrid ItemsSource="{Binding Logs}" SelectedItem="{Binding SelectedLog}"
                IsReadOnly="True" GridLinesVisibility="Horizontal"
                AutoGenerateColumns="False" CanUserResizeColumns="True">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60" />
          <DataGridTextColumn Header="Date" Binding="{Binding TimeText}" Width="2*" />
          <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="*" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <ProgressBar Grid.Row="2" Margin="0,8,0,0" Minimum="0" Maximum="100"
                 Value="{Binding Progress}" Height="16" />

    <TextBlock Grid.Row="3" Margin="0,6,0,0" Foreground="#BBB" Text="{Binding Status}"
               TextWrapping="Wrap" />
  </Grid>
</Window>
