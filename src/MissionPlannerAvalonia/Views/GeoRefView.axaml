<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  mc:Ignorable="d"
  d:DesignWidth="900"
  d:DesignHeight="620"
  x:Class="MissionPlannerAvalonia.Views.GeoRefView"
  x:DataType="vm:GeoRefViewModel"
  Background="#434445"
>
  <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
    <!-- Log file -->
    <Grid Grid.Row="0" ColumnDefinitions="120,*,Auto" Margin="0,0,0,6">
      <TextBlock Grid.Column="0" Text="Log file:" Foreground="#DDD" VerticalAlignment="Center" />
      <TextBox Grid.Column="1" Text="{Binding LogPath}" />
      <Button Grid.Column="2" x:Name="BrowseLogBtn" Content="Browse…" Margin="6,0,0,0" />
    </Grid>

    <!-- Photo dir -->
    <Grid Grid.Row="1" ColumnDefinitions="120,*,Auto" Margin="0,0,0,6">
      <TextBlock Grid.Column="0" Text="Photo folder:" Foreground="#DDD" VerticalAlignment="Center" />
      <TextBox Grid.Column="1" Text="{Binding PhotoDir}" />
      <Button Grid.Column="2" x:Name="BrowseDirBtn" Content="Browse…" Margin="6,0,0,0" />
    </Grid>

    <!-- Options -->
    <WrapPanel Grid.Row="2" Orientation="Horizontal" ItemSpacing="14" LineSpacing="6" Margin="0,0,0,6">
      <RadioButton GroupName="mode" Content="CAM message sync" IsChecked="{Binding UseCamMessages}"
                   Foreground="#DDD" />
      <RadioButton GroupName="mode" Content="Time offset" Foreground="#DDD" />
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Text="Offset (s):" Foreground="#DDD" VerticalAlignment="Center" />
        <TextBox Width="80" Text="{Binding TimeOffsetSeconds}" />
      </StackPanel>
      <CheckBox Content="Use GPS2" IsChecked="{Binding UseGps2}" Foreground="#DDD" />
    </WrapPanel>

    <!-- Actions -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button x:Name="GeoTagBtn" Content="Geo Tag" />
      <TextBlock Text="{Binding Status}" Foreground="#9Fd" VerticalAlignment="Center" />
    </StackPanel>

    <!-- Results -->
    <DataGrid Grid.Row="4" x:Name="ResultsGrid" ItemsSource="{Binding Results}"
              IsReadOnly="True" AutoGenerateColumns="False" Background="#2b2c2d">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Photo" Binding="{Binding Photo}" Width="2*" />
        <DataGridTextColumn Header="Lat" Binding="{Binding Lat}" Width="*" />
        <DataGridTextColumn Header="Lng" Binding="{Binding Lng}" Width="*" />
        <DataGridTextColumn Header="Alt" Binding="{Binding Alt}" Width="*" />
        <DataGridTextColumn Header="Matched time" Binding="{Binding MatchedTime}" Width="1.5*" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- Output log -->
    <TextBox Grid.Row="5" Text="{Binding OutputLog}" IsReadOnly="True" AcceptsReturn="True"
             TextWrapping="NoWrap" Height="130" Margin="0,8,0,0"
             FontFamily="Consolas,Menlo,monospace" Background="#1e1f20" Foreground="#CCC"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
  </Grid>
</UserControl>
