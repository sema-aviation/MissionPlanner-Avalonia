<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="440"
  d:DesignHeight="240"
  x:Class="MissionPlannerAvalonia.Views.MavlinkLogWindow"
  x:DataType="vm:MavlinkLogConvertViewModel"
  Background="{DynamicResource MpControlBg}"
  Width="460"
  Height="250"
  CanResize="False"
  WindowStartupLocation="CenterOwner"
  Title="Tlog Convert"
>
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*,Auto">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
      <Button Content="Pick .tlog…" Command="{Binding PickTlogCommand}" />
      <TextBlock VerticalAlignment="Center" Foreground="WhiteSmoke" Text="{Binding TlogName}" />
    </StackPanel>

    <TextBlock Grid.Row="1" Margin="0,14,0,6" Foreground="#BBB" Text="Convert to:" />

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
      <Button Content="KML" Command="{Binding ConvertKmlCommand}"
              IsEnabled="{Binding HasFile}" MinWidth="80" />
      <Button Content="GPX" Command="{Binding ConvertGpxCommand}"
              IsEnabled="{Binding HasFile}" MinWidth="80" />
      <Button Content="Matlab" Command="{Binding ConvertMatlabCommand}"
              IsEnabled="{Binding HasFile}" MinWidth="80" />
    </StackPanel>

    <TextBlock Grid.Row="4" Foreground="#9AD" TextWrapping="Wrap" Text="{Binding Status}" />
  </Grid>
</Window>
