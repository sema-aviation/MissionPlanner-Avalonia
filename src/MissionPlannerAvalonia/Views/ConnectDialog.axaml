<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="MissionPlannerAvalonia.Views.ConnectDialog"
  Width="360"
  SizeToContent="Height"
  CanResize="False"
  WindowStartupLocation="CenterOwner"
  Background="#262728"
  Title="Connection"
>
  <StackPanel Margin="16" Spacing="10">
    <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="14" />

    <StackPanel x:Name="Field1Panel" Spacing="3">
      <TextBlock x:Name="Label1" />
      <TextBox x:Name="Value1" />
    </StackPanel>

    <StackPanel x:Name="Field2Panel" Spacing="3">
      <TextBlock x:Name="Label2" />
      <TextBox x:Name="Value2" />
    </StackPanel>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,6,0,0">
      <Button x:Name="OkButton" Content="OK" MinWidth="80" IsDefault="True" />
      <Button x:Name="CancelButton" Content="Cancel" MinWidth="80" IsCancel="True" />
    </StackPanel>
  </StackPanel>
</Window>
