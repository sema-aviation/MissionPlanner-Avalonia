<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  mc:Ignorable="d"
  d:DesignWidth="780"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.AntennaTrackerView"
  x:DataType="vm:AntennaTrackerUIViewModel"
  Background="#434445"
>
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="10">
      <TextBlock Classes="pagetitle" Text="Antenna Tracker" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox
          MinWidth="130"
          ItemsSource="{Binding Interfaces}"
          SelectedItem="{Binding SelectedInterface}"
          IsEnabled="{Binding ControlsEnabled}"
        />
        <ComboBox
          MinWidth="120"
          ItemsSource="{Binding Ports}"
          SelectedItem="{Binding SelectedPort}"
          IsEnabled="{Binding ControlsEnabled}"
        />
        <ComboBox
          MinWidth="100"
          ItemsSource="{Binding Bauds}"
          SelectedItem="{Binding SelectedBaud}"
          IsEnabled="{Binding ControlsEnabled}"
        />
        <Button Content="{Binding ConnectText}" Command="{Binding ConnectCommand}" />
        <Button Content="Find Trim Pan (SiK Radio)" Command="{Binding FindTrimPanCommand}" />
      </StackPanel>

      <TextBlock
        Foreground="#E2A33A"
        FontWeight="Bold"
        Text="Misusing this interface can cause servo damage, use with caution!!!"
      />

      <!-- Live readout + mode -->
      <Border Background="#2D2D2D" CornerRadius="4" Padding="12">
        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="Vehicle Az" />
          <TextBlock Grid.Row="1" Grid.Column="0" FontSize="18" FontWeight="Bold"
                     Foreground="#94C11F" Text="{Binding VehicleAzimuth}" />
          <TextBlock Grid.Row="0" Grid.Column="1" Classes="fieldlbl" Text="Vehicle El" />
          <TextBlock Grid.Row="1" Grid.Column="1" FontSize="18" FontWeight="Bold"
                     Foreground="#94C11F" Text="{Binding VehicleElevation}" />
          <TextBlock Grid.Row="0" Grid.Column="2" Classes="fieldlbl" Text="Commanded Az" />
          <TextBlock Grid.Row="1" Grid.Column="2" FontSize="18" FontWeight="Bold"
                     Text="{Binding CommandedAzimuth}" />
          <TextBlock Grid.Row="0" Grid.Column="3" Classes="fieldlbl" Text="Commanded El" />
          <TextBlock Grid.Row="1" Grid.Column="3" FontSize="18" FontWeight="Bold"
                     Text="{Binding CommandedElevation}" />
        </Grid>
      </Border>

      <!-- Manual slew -->
      <Border Background="#2D2D2D" CornerRadius="4" Padding="12">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <CheckBox Content="Manual Slew (override point-at-vehicle)"
                      IsChecked="{Binding ManualMode}" />
            <Button Content="Home / Center" Command="{Binding HomeCenterCommand}" />
          </StackPanel>

          <Grid ColumnDefinitions="90,*,70" RowDefinitions="Auto,Auto" RowSpacing="6">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="Azimuth"
                       VerticalAlignment="Center" />
            <Slider Grid.Row="0" Grid.Column="1" Minimum="-180" Maximum="180"
                    Value="{Binding ManualAzimuth}" IsEnabled="{Binding ManualMode}" />
            <TextBlock Grid.Row="0" Grid.Column="2" Classes="fieldlbl"
                       Text="{Binding ManualAzimuth, StringFormat='{}{0:0}°'}"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldlbl" Text="Elevation"
                       VerticalAlignment="Center" />
            <Slider Grid.Row="1" Grid.Column="1" Minimum="-90" Maximum="90"
                    Value="{Binding ManualElevation}" IsEnabled="{Binding ManualMode}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Classes="fieldlbl"
                       Text="{Binding ManualElevation, StringFormat='{}{0:0}°'}"
                       VerticalAlignment="Center" />
          </Grid>
        </StackPanel>
      </Border>

      <Grid ColumnDefinitions="*,12,*">
        <!-- Pan -->
        <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="4" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Classes="fieldlbl" FontSize="15" Text="Pan" />

            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="Range / Angle" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PanRange}" IsEnabled="{Binding ControlsEnabled}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldlbl" Text="PWM Range" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PanPwmRange}" IsEnabled="{Binding ControlsEnabled}" />

              <TextBlock Grid.Row="2" Grid.Column="0" Classes="fieldlbl" Text="Center PWM" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PanCenter}" IsEnabled="{Binding ControlsEnabled}" />

              <TextBlock Grid.Row="3" Grid.Column="0" Classes="fieldlbl" Text="Speed" VerticalAlignment="Center" />
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PanSpeed}"
                       IsEnabled="{Binding SpeedAccelEnabled}" />

              <TextBlock Grid.Row="4" Grid.Column="0" Classes="fieldlbl" Text="Acceleration" VerticalAlignment="Center" />
              <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PanAccel}"
                       IsEnabled="{Binding SpeedAccelEnabled}" />
            </Grid>

            <StackPanel Spacing="2">
              <TextBlock Classes="fieldlbl" Text="{Binding PanTrim, StringFormat='Trim: {0:0}'}" />
              <Slider
                Minimum="{Binding PanTrimMin}"
                Maximum="{Binding PanTrimMax}"
                Value="{Binding PanTrim}"
                TickFrequency="5"
                TickPlacement="BottomRight"
              />
            </StackPanel>

            <CheckBox Content="Reverse" IsChecked="{Binding PanReverse}" />
          </StackPanel>
        </Border>

        <!-- Tilt -->
        <Border Grid.Column="2" Background="#2D2D2D" CornerRadius="4" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Classes="fieldlbl" FontSize="15" Text="Tilt" />

            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="Range / Angle" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TiltRange}" IsEnabled="{Binding ControlsEnabled}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldlbl" Text="PWM Range" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TiltPwmRange}" IsEnabled="{Binding ControlsEnabled}" />

              <TextBlock Grid.Row="2" Grid.Column="0" Classes="fieldlbl" Text="Center PWM" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TiltCenter}" IsEnabled="{Binding ControlsEnabled}" />

              <TextBlock Grid.Row="3" Grid.Column="0" Classes="fieldlbl" Text="Speed" VerticalAlignment="Center" />
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TiltSpeed}"
                       IsEnabled="{Binding SpeedAccelEnabled}" />

              <TextBlock Grid.Row="4" Grid.Column="0" Classes="fieldlbl" Text="Acceleration" VerticalAlignment="Center" />
              <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding TiltAccel}"
                       IsEnabled="{Binding SpeedAccelEnabled}" />
            </Grid>

            <StackPanel Spacing="2">
              <TextBlock Classes="fieldlbl" Text="{Binding TiltTrim, StringFormat='Trim: {0:0}'}" />
              <Slider
                Minimum="{Binding TiltTrimMin}"
                Maximum="{Binding TiltTrimMax}"
                Value="{Binding TiltTrim}"
                TickFrequency="5"
                TickPlacement="BottomRight"
              />
            </StackPanel>

            <CheckBox Content="Reverse" IsChecked="{Binding TiltReverse}" />
          </StackPanel>
        </Border>
      </Grid>

      <TextBlock Text="{Binding Status}" Foreground="#94C11F" TextWrapping="Wrap" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
