<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  xmlns:views="using:MissionPlannerAvalonia.Views"
  xmlns:ctl="using:MissionPlannerAvalonia.Controls"
  mc:Ignorable="d"
  d:DesignWidth="1100"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.FlightDataView"
  x:DataType="vm:FlightDataViewModel"
  Background="#434445"
>
  <Grid ColumnDefinitions="2*,4,3*">
    <Grid Grid.Column="0" RowDefinitions="*,4,*">
      <Border Grid.Row="0" Background="Black">
        <ctl:HudControl
          Roll="{Binding Roll}"
          Pitch="{Binding Pitch}"
          Yaw="{Binding Yaw}"
          Alt="{Binding Alt}"
          AirSpeed="{Binding AirSpeed}"
          GroundSpeed="{Binding GroundSpeed}"
          VerticalSpeed="{Binding VerticalSpeed}"
          SatCount="{Binding SatCount}"
          Armed="{Binding Armed}"
          Mode="{Binding Mode}"
          BatteryVoltage="{Binding BatteryVoltage}"
          BatteryRemaining="{Binding BatteryRemaining}"
        />
      </Border>

      <GridSplitter Grid.Row="1" Background="#262728" ResizeDirection="Rows" />

      <TabControl Grid.Row="2" Background="#434445">
        <TabItem Header="Quick">
          <UniformGrid Columns="2" Rows="3" Margin="2">
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding Alt, StringFormat={}{0:0.00}}"
                  Foreground="#D197F8"
                  Classes="qval"
                />
                <TextBlock Text="Altitude (m)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding GroundSpeed, StringFormat={}{0:0.00}}"
                  Foreground="#FE842E"
                  Classes="qval"
                />
                <TextBlock Text="GroundSpeed (m/s)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding WpDist, StringFormat={}{0:0.00}}"
                  Foreground="#FF605B"
                  Classes="qval"
                />
                <TextBlock Text="Dist to WP (m)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding Yaw, StringFormat={}{0:0.00}}"
                  Foreground="#00FF53"
                  Classes="qval"
                />
                <TextBlock Text="Yaw (deg)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding VerticalSpeed, StringFormat={}{0:0.00}}"
                  Foreground="#FEFE56"
                  Classes="qval"
                />
                <TextBlock Text="Vertical Speed (m/s)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding DistToHome, StringFormat={}{0:0.00}}"
                  Foreground="#00FFFC"
                  Classes="qval"
                />
                <TextBlock Text="DistToMAV" Classes="qlbl" />
              </StackPanel>
            </Border>
          </UniformGrid>
        </TabItem>

        <TabItem Header="Actions">
          <ScrollViewer>
            <StackPanel Margin="6" Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <ComboBox Width="160" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" />
                <Button Content="Set Mode" Command="{Binding SetModeCommand}" />
                <Button Content="{Binding ArmText}" Command="{Binding ToggleArmCommand}" MinWidth="90" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="Auto" Command="{Binding QuickAutoCommand}" MinWidth="80" />
                <Button Content="Loiter" Command="{Binding QuickLoiterCommand}" MinWidth="80" />
                <Button Content="RTL" Command="{Binding QuickRtlCommand}" MinWidth="80" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <ComboBox Width="220" ItemsSource="{Binding Actions}" SelectedItem="{Binding SelectedAction}" />
                <Button Content="Do Action" Command="{Binding DoActionCommand}" MinWidth="90" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Set WP #" VerticalAlignment="Center" />
                <NumericUpDown Width="100" Minimum="0" Maximum="700" Value="{Binding SetWpIndex}" />
                <Button Content="Set WP" Command="{Binding SetWpCommand}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Home Alt (m)" VerticalAlignment="Center" />
                <NumericUpDown Width="110" Value="{Binding HomeAlt}" />
                <Button Content="Set Home Alt" Command="{Binding SetHomeCommand}" />
                <Button Content="Abort Land" Command="{Binding AbortLandCommand}" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Messages">
          <TextBox
            Text="{Binding Messages}"
            AcceptsReturn="True"
            IsReadOnly="True"
            TextWrapping="Wrap"
            Background="#1F1F20"
            Foreground="WhiteSmoke"
          />
        </TabItem>

        <TabItem Header="PreFlight">
          <StackPanel Margin="10" Spacing="6">
            <Panel>
              <TextBlock
                Text="{Binding PrearmText}"
                FontWeight="Bold"
                FontSize="16"
                Foreground="#E03030"
                IsVisible="{Binding !PrearmOk}"
              />
              <TextBlock
                Text="{Binding PrearmText}"
                FontWeight="Bold"
                FontSize="16"
                Foreground="#94C11F"
                IsVisible="{Binding PrearmOk}"
              />
            </Panel>
            <TextBlock Text="{Binding Mode, StringFormat=Mode: {0}}" />
            <TextBlock Text="{Binding Armed, StringFormat=Armed: {0}}" />
            <TextBlock Text="{Binding SatCount, StringFormat=GPS Satellites: {0}}" />
            <TextBlock Text="{Binding GpsHdop, StringFormat=HDOP: {0:0.00}}" />
            <TextBlock Text="{Binding BatteryVoltage, StringFormat=Battery: {0:0.00} V}" />
            <TextBlock Text="{Binding EkfStatus, StringFormat=EKF status: {0:0.00}}" />
          </StackPanel>
        </TabItem>

        <TabItem Header="Gauges">
          <Grid Margin="6" RowDefinitions="*,*" ColumnDefinitions="*,*">
            <ctl:Gauge Grid.Row="0" Grid.Column="0" Margin="6" MinHeight="120"
                       Label="Airspeed" Units="m/s" Min="0" Max="50" Value="{Binding AirSpeed}" />
            <ctl:Gauge Grid.Row="0" Grid.Column="1" Margin="6" MinHeight="120"
                       Label="Altitude" Units="m" Min="0" Max="200" Value="{Binding Alt}" />
            <ctl:Gauge Grid.Row="1" Grid.Column="0" Margin="6" MinHeight="120"
                       Label="Heading" Units="deg" Min="0" Max="360" Value="{Binding Yaw}" />
            <ctl:Gauge Grid.Row="1" Grid.Column="1" Margin="6" MinHeight="120"
                       Label="Climb" Units="m/s" Min="-10" Max="10" Value="{Binding VerticalSpeed}" />
          </Grid>
        </TabItem>

        <TabItem Header="Transponder">
          <TextBlock Margin="8" Text="Transponder" />
        </TabItem>

        <TabItem Header="Status">
          <ScrollViewer>
            <StackPanel Margin="8" Spacing="3">
              <TextBlock Text="{Binding Mode, StringFormat=Mode: {0}}" />
              <TextBlock Text="{Binding Armed, StringFormat=Armed: {0}}" />
              <TextBlock Text="{Binding BatteryVoltage, StringFormat=Battery: {0:0.00} V}" />
              <TextBlock Text="{Binding BatteryRemaining, StringFormat=Battery remaining: {0}%}" />
              <TextBlock Text="{Binding SatCount, StringFormat=Satellites: {0}}" />
              <TextBlock Text="{Binding GpsHdop, StringFormat=HDOP: {0:0.00}}" />
              <TextBlock Text="{Binding Roll, StringFormat=Roll: {0:0.0}}" />
              <TextBlock Text="{Binding Pitch, StringFormat=Pitch: {0:0.0}}" />
              <TextBlock Text="{Binding Yaw, StringFormat=Yaw: {0:0}}" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Servo/Relay">
          <ScrollViewer>
            <StackPanel Margin="8" Spacing="8">
              <TextBlock Text="Servo output (live)" FontWeight="Bold" />
              <ItemsControl ItemsSource="{Binding Servos}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ServoOut">
                    <Grid ColumnDefinitions="70,*,60" Margin="0,3">
                      <TextBlock
                        Grid.Column="0"
                        Text="{Binding Number, StringFormat='Servo \{0\}'}"
                        VerticalAlignment="Center"
                      />
                      <ProgressBar
                        Grid.Column="1"
                        Minimum="1000"
                        Maximum="2000"
                        Value="{Binding Value}"
                        Height="20"
                        Foreground="#94C11F"
                      />
                      <TextBlock
                        Grid.Column="2"
                        Text="{Binding Value}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                      />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="Servo override" FontWeight="Bold" Margin="0,8,0,0" />
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Ch" VerticalAlignment="Center" />
                <NumericUpDown Width="90" Minimum="1" Maximum="16" Value="{Binding ServoNumber}" />
                <TextBlock Text="PWM" VerticalAlignment="Center" />
                <NumericUpDown Width="110" Minimum="800" Maximum="2200" Value="{Binding ServoPwm}" />
                <Button Content="Set Servo" Command="{Binding SetServoCommand}" />
              </StackPanel>

              <TextBlock Text="Relays" FontWeight="Bold" Margin="0,8,0,0" />
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="Relay 0" Command="{Binding ToggleRelayCommand}" CommandParameter="0" />
                <Button Content="Relay 1" Command="{Binding ToggleRelayCommand}" CommandParameter="1" />
                <Button Content="Relay 2" Command="{Binding ToggleRelayCommand}" CommandParameter="2" />
                <Button Content="Relay 3" Command="{Binding ToggleRelayCommand}" CommandParameter="3" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Payload Control">
          <StackPanel Margin="10" Spacing="8">
            <TextBlock Text="Gimbal" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Pitch" VerticalAlignment="Center" Width="44" />
              <Slider Width="240" Minimum="-90" Maximum="45" Value="{Binding GimbalPitch}" />
              <TextBlock Text="{Binding GimbalPitch, StringFormat={}{0:0}°}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Yaw" VerticalAlignment="Center" Width="44" />
              <Slider Width="240" Minimum="-180" Maximum="180" Value="{Binding GimbalYaw}" />
              <TextBlock Text="{Binding GimbalYaw, StringFormat={}{0:0}°}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Point Gimbal" Command="{Binding PointGimbalCommand}" />
              <Button Content="Trigger Camera" Command="{Binding TriggerCameraCommand}" />
            </StackPanel>
          </StackPanel>
        </TabItem>
        <TabItem Header="Telemetry Logs">
          <views:LogBrowseView DataContext="{Binding TelemetryLogs}" />
        </TabItem>
        <TabItem Header="DataFlash Logs">
          <views:LogBrowseView DataContext="{Binding DataFlashLogs}" />
        </TabItem>
        <TabItem Header="Scripts">
          <StackPanel Margin="8" Spacing="6">
            <TextBlock Text="Automation script" FontWeight="Bold" />
            <TextBox
              AcceptsReturn="True"
              Height="160"
              Background="#1F1F20"
              Foreground="WhiteSmoke"
              FontFamily="monospace"
            />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Run" IsEnabled="False" />
              <Button Content="Stop" IsEnabled="False" />
            </StackPanel>
            <TextBlock
              Text="The embedded Python automation engine (IronPython) is not bundled in this cross-platform build."
              Foreground="#C8A03C"
              TextWrapping="Wrap"
            />
          </StackPanel>
        </TabItem>
      </TabControl>
    </Grid>

    <GridSplitter Grid.Column="1" Background="#262728" ResizeDirection="Columns" />

    <ctl:MapView Grid.Column="2" />
  </Grid>
</UserControl>
