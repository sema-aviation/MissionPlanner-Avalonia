<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  xmlns:views="using:MissionPlannerAvalonia.Views"
  xmlns:ctl="using:MissionPlannerAvalonia.Controls"
  mc:Ignorable="d"
  d:DesignWidth="1100"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.FlightDataView"
  x:DataType="vm:FlightDataViewModel"
  Background="#434445"
>
  <Grid ColumnDefinitions="2*,4,3*">
    <Grid Grid.Column="0" RowDefinitions="*,4,*">
      <Border Grid.Row="0" Background="Black">
        <ctl:HudControl
          Roll="{Binding Roll}"
          Pitch="{Binding Pitch}"
          Yaw="{Binding Yaw}"
          Alt="{Binding Alt}"
          AirSpeed="{Binding AirSpeed}"
          GroundSpeed="{Binding GroundSpeed}"
          VerticalSpeed="{Binding VerticalSpeed}"
          SatCount="{Binding SatCount}"
          Armed="{Binding Armed}"
          Mode="{Binding Mode}"
          BatteryVoltage="{Binding BatteryVoltage}"
          BatteryRemaining="{Binding BatteryRemaining}"
        />
      </Border>

      <GridSplitter Grid.Row="1" Background="#262728" ResizeDirection="Rows" />

      <TabControl Grid.Row="2" Background="#434445">
        <TabItem Header="Quick">
          <UniformGrid Columns="2" Rows="3" Margin="2">
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding Alt, StringFormat={}{0:0.00}}"
                  Foreground="#D197F8"
                  Classes="qval"
                />
                <TextBlock Text="Altitude (m)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding GroundSpeed, StringFormat={}{0:0.00}}"
                  Foreground="#FE842E"
                  Classes="qval"
                />
                <TextBlock Text="GroundSpeed (m/s)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding WpDist, StringFormat={}{0:0.00}}"
                  Foreground="#FF605B"
                  Classes="qval"
                />
                <TextBlock Text="Dist to WP (m)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding Yaw, StringFormat={}{0:0.00}}"
                  Foreground="#00FF53"
                  Classes="qval"
                />
                <TextBlock Text="Yaw (deg)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding VerticalSpeed, StringFormat={}{0:0.00}}"
                  Foreground="#FEFE56"
                  Classes="qval"
                />
                <TextBlock Text="Vertical Speed (m/s)" Classes="qlbl" />
              </StackPanel>
            </Border>
            <Border Classes="qv">
              <StackPanel>
                <TextBlock
                  Text="{Binding DistToHome, StringFormat={}{0:0.00}}"
                  Foreground="#00FFFC"
                  Classes="qval"
                />
                <TextBlock Text="DistToMAV" Classes="qlbl" />
              </StackPanel>
            </Border>
          </UniformGrid>
        </TabItem>

        <TabItem Header="Actions">
          <ScrollViewer>
            <Grid Margin="6" ColumnDefinitions="*,*,*,*,Auto"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="3" RowSpacing="3">
              <!-- Row 0 -->
              <ComboBox Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Actions}" SelectedItem="{Binding SelectedAction}" />
              <Button Grid.Row="0" Grid.Column="1" Content="Do Action" HorizontalAlignment="Stretch"
                      Command="{Binding DoActionCommand}" />
              <Button Grid.Row="0" Grid.Column="2" Content="Auto" HorizontalAlignment="Stretch"
                      Command="{Binding QuickAutoCommand}" />
              <Button Grid.Row="0" Grid.Column="3" Content="Set Home Alt" HorizontalAlignment="Stretch"
                      Command="{Binding SetHomeCommand}" />
              <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="2">
                <Button Content="Change Speed" Command="{Binding ChangeSpeedCommand}" />
                <NumericUpDown Width="86" FormatString="0.0" Value="{Binding ChangeSpeedValue}" />
              </StackPanel>

              <!-- Row 1 -->
              <ComboBox Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch"
                        ItemsSource="{Binding WpNumbers}" SelectedItem="{Binding SetWpIndex}" />
              <Button Grid.Row="1" Grid.Column="1" Content="Set WP" HorizontalAlignment="Stretch"
                      Command="{Binding SetWpCommand}" />
              <Button Grid.Row="1" Grid.Column="2" Content="Loiter" HorizontalAlignment="Stretch"
                      Command="{Binding QuickLoiterCommand}" />
              <Button Grid.Row="1" Grid.Column="3" Content="Restart Mission" HorizontalAlignment="Stretch"
                      Command="{Binding RestartMissionCommand}" />
              <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="2">
                <Button Content="Change Alt" Command="{Binding ChangeAltCommand}" />
                <NumericUpDown Width="86" FormatString="0.0" Value="{Binding ChangeAltValue}" />
              </StackPanel>

              <!-- Row 2 -->
              <ComboBox Grid.Row="2" Grid.Column="0" HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" />
              <Button Grid.Row="2" Grid.Column="1" Content="Set Mode" HorizontalAlignment="Stretch"
                      Command="{Binding SetModeCommand}" />
              <Button Grid.Row="2" Grid.Column="2" Content="RTL" HorizontalAlignment="Stretch"
                      Command="{Binding QuickRtlCommand}" />
              <Button Grid.Row="2" Grid.Column="3" Content="Raw Sensor View" HorizontalAlignment="Stretch"
                      Command="{Binding RawSensorViewCommand}" />
              <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal" Spacing="2">
                <Button Content="Set Loiter Rad" Command="{Binding SetLoiterRadCommand}" />
                <NumericUpDown Width="86" FormatString="0" Value="{Binding LoiterRadValue}" />
              </StackPanel>

              <!-- Row 3 -->
              <ComboBox Grid.Row="3" Grid.Column="0" HorizontalAlignment="Stretch"
                        ItemsSource="{Binding MountModes}" SelectedItem="{Binding SelectedMountMode}" />
              <Button Grid.Row="3" Grid.Column="1" Content="Set Mount" HorizontalAlignment="Stretch"
                      Command="{Binding SetMountCommand}" />
              <Button Grid.Row="3" Grid.Column="2" Content="Joystick" HorizontalAlignment="Stretch"
                      Command="{Binding JoystickCommand}" />
              <Button Grid.Row="3" Grid.Column="3" Content="Arm/ Disarm" HorizontalAlignment="Stretch"
                      Command="{Binding ToggleArmCommand}" />
              <Button Grid.Row="3" Grid.Column="4" Content="Clear Track" HorizontalAlignment="Stretch"
                      Command="{Binding ClearTrackCommand}" />

              <!-- Row 4 -->
              <Button Grid.Row="4" Grid.Column="2" Content="Message" HorizontalAlignment="Stretch"
                      Command="{Binding ShowMessageCommand}" />
              <Button Grid.Row="4" Grid.Column="3" Content="Resume Mission" HorizontalAlignment="Stretch"
                      Command="{Binding ResumeMissionCommand}" />
              <Button Grid.Row="4" Grid.Column="4" Content="Abort Landing" HorizontalAlignment="Stretch"
                      Command="{Binding AbortLandCommand}" />
            </Grid>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Actions">
          <StackPanel Margin="10" Spacing="8">
            <Button Content="Loiter" HorizontalAlignment="Stretch" Height="44" FontSize="15"
                    Command="{Binding QuickLoiterCommand}" />
            <Button Content="RTL" HorizontalAlignment="Stretch" Height="44" FontSize="15"
                    Command="{Binding QuickRtlCommand}" />
            <Button Content="Auto" HorizontalAlignment="Stretch" Height="44" FontSize="15"
                    Command="{Binding QuickAutoCommand}" />
          </StackPanel>
        </TabItem>

        <TabItem Header="Messages">
          <TextBox
            Text="{Binding Messages}"
            AcceptsReturn="True"
            IsReadOnly="True"
            TextWrapping="Wrap"
            Background="#1F1F20"
            Foreground="WhiteSmoke"
          />
        </TabItem>

        <TabItem Header="PreFlight">
          <DockPanel Margin="6">
            <Button DockPanel.Dock="Top" HorizontalAlignment="Right" Content="Edit" Width="60" />
            <ItemsControl ItemsSource="{Binding PreflightChecks}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CheckItem">
                  <Grid ColumnDefinitions="*,120,28" Margin="0,2" Background="#3A3B3C">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="6,4" VerticalAlignment="Center" />
                    <Panel Grid.Column="1">
                      <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Foreground="#94C11F"
                                 IsVisible="{Binding Ok}" />
                      <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Foreground="#E03030"
                                 IsVisible="{Binding !Ok}" />
                    </Panel>
                    <CheckBox Grid.Column="2" IsChecked="{Binding Ok, Mode=OneWay}" IsHitTestVisible="False" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DockPanel>
        </TabItem>

        <TabItem Header="Gauges">
          <Grid Margin="6" RowDefinitions="*,*" ColumnDefinitions="*,*">
            <ctl:Gauge Grid.Row="0" Grid.Column="0" Margin="6" MinHeight="120"
                       Label="VSI" Units="m/s" Min="-10" Max="10" Value="{Binding VerticalSpeed}" />
            <ctl:Gauge Grid.Row="0" Grid.Column="1" Margin="6" MinHeight="120"
                       Label="Speed" Units="m/s" Min="0" Max="50" Value="{Binding AirSpeed}" />
            <ctl:Gauge Grid.Row="1" Grid.Column="0" Margin="6" MinHeight="120"
                       Label="Alt" Units="m" Min="0" Max="200" Value="{Binding Alt}" />
            <ctl:Gauge Grid.Row="1" Grid.Column="1" Margin="6" MinHeight="120"
                       Label="Heading" Units="deg" Min="0" Max="360" Value="{Binding Yaw}" />
          </Grid>
        </TabItem>

        <TabItem Header="Transponder">
          <TextBlock Margin="8" Text="Transponder" />
        </TabItem>

        <TabItem Header="Status">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Statuses}" Margin="6">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:StatusItem">
                  <Grid Width="200" ColumnDefinitions="*,Auto" Margin="2,1">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#BBBBBB" FontSize="11" />
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Servo/Relay">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding ServoChannels}" Margin="4">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ServoChannel">
                  <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,1">
                    <Button Content="Low" Width="40" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetServoChannelCommand}"
                            CommandParameter="{Binding Number, StringFormat='{}{0}:low'}" />
                    <Button Content="Mid" Width="40" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetServoChannelCommand}"
                            CommandParameter="{Binding Number, StringFormat='{}{0}:mid'}" />
                    <Button Content="High" Width="40" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetServoChannelCommand}"
                            CommandParameter="{Binding Number, StringFormat='{}{0}:high'}" />
                    <Button Content="Toggle" Width="50" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetServoChannelCommand}"
                            CommandParameter="{Binding Number, StringFormat='{}{0}:toggle'}" />
                    <Border Background="#C00000" Width="54" Margin="6,0,0,0">
                      <TextBlock Text="{Binding Number}" Foreground="White" FontSize="11"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBox Width="44" FontSize="11" Padding="2,1"
                             Text="{Binding Min}" />
                    <TextBox Width="44" FontSize="11" Padding="2,1"
                             Text="{Binding Max}" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Payload Control">
          <Grid Margin="10" ColumnDefinitions="Auto,*" RowDefinitions="*,Auto">
            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,20,0">
              <TextBlock Text="Tilt" HorizontalAlignment="Center" />
              <Slider Orientation="Vertical" Height="180" Minimum="-90" Maximum="45"
                      Value="{Binding Tilt}" HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="14" VerticalAlignment="Top">
              <StackPanel Spacing="2">
                <TextBlock Text="Pan" />
                <Slider Minimum="-180" Maximum="180" Value="{Binding Pan}" />
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="Roll" />
                <Slider Minimum="-90" Maximum="90" Value="{Binding Roll2}" />
              </StackPanel>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal"
                        Spacing="6" Margin="0,12,0,0">
              <Button Content="Reset Position" Command="{Binding ResetPositionCommand}" />
              <Button Content="Point" Command="{Binding PointMountCommand}" />
              <Button Content="Video Control" Command="{Binding TriggerCameraCommand}" />
            </StackPanel>
          </Grid>
        </TabItem>
        <TabItem Header="Scripts">
          <StackPanel Margin="8" Spacing="6">
            <TextBlock Text="{Binding ScriptStatus, StringFormat=Script Status: {0}}" />
            <TextBlock Text="{Binding SelectedScript, StringFormat=Selected Script: {0}}" />
            <CheckBox Content="Redirect Program Output" IsChecked="{Binding RedirectOutput}" />
            <Button Content="Select Script" Command="{Binding SelectScriptCommand}" HorizontalAlignment="Left" />
          </StackPanel>
        </TabItem>

        <TabItem Header="Telemetry Logs">
          <StackPanel Margin="8" Spacing="8">
            <Button Content="Load Log" HorizontalAlignment="Left" Command="{Binding DownloadDataflashLogCommand}" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Play" />
              <Slider Width="240" Minimum="0" Maximum="100" />
              <TextBlock Text="0.00 %" VerticalAlignment="Center" />
            </StackPanel>
            <Button Content="Tlog > Kml or Graph" HorizontalAlignment="Left" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Speed" VerticalAlignment="Center" />
              <TextBlock Text="x 1.0" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding LogStatus}" Foreground="#C8A03C" TextWrapping="Wrap" />
          </StackPanel>
        </TabItem>

        <TabItem Header="DataFlash Logs">
          <WrapPanel Margin="8">
            <Button Content="Download DataFlash Log Via Mavlink" Margin="3"
                    Command="{Binding DownloadDataflashLogCommand}" />
            <Button Content="Review a Log" Margin="3" />
            <Button Content="Auto Analysis" Margin="3" />
            <Button Content="Create KML + gpx" Margin="3" />
            <Button Content="Convert Bin to Log" Margin="3" />
            <Button Content="Create Matlab File" Margin="3" />
            <Button Content="Geo Reference Images" Margin="3" />
            <TextBlock Text="{Binding LogStatus}" Foreground="#C8A03C" TextWrapping="Wrap"
                       Width="320" Margin="3" />
          </WrapPanel>
        </TabItem>
      </TabControl>
    </Grid>

    <GridSplitter Grid.Column="1" Background="#262728" ResizeDirection="Columns" />

    <ctl:MapView Grid.Column="2" />
  </Grid>
</UserControl>
