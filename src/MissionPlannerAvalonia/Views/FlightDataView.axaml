<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  xmlns:views="using:MissionPlannerAvalonia.Views"
  xmlns:ctl="using:MissionPlannerAvalonia.Controls"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  mc:Ignorable="d"
  d:DesignWidth="1100"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.FlightDataView"
  x:DataType="vm:FlightDataViewModel"
  Background="#434445"
>
  <Grid ColumnDefinitions="2*,4,3*">
    <Grid Grid.Column="{Binding HudColumn}" RowDefinitions="*,4,*">
      <Border Grid.Row="0" Background="Black">
        <ctl:HudControl
          x:Name="Hud"
          Roll="{Binding Roll}"
          Pitch="{Binding Pitch}"
          Yaw="{Binding Yaw}"
          Alt="{Binding Alt}"
          AirSpeed="{Binding AirSpeed}"
          GroundSpeed="{Binding GroundSpeed}"
          VerticalSpeed="{Binding VerticalSpeed}"
          SatCount="{Binding SatCount}"
          Armed="{Binding Armed}"
          Mode="{Binding Mode}"
          BatteryVoltage="{Binding BatteryVoltage}"
          BatteryRemaining="{Binding BatteryRemaining}"
          ShowIcons="{Binding HudShowIcons}"
          Russian="{Binding HudRussian}"
          BatteryCells="{Binding HudBatteryCells}"
          GroundColorHex="{Binding HudGroundColor}"
          NavBearing="{Binding NavBearing}"
          CurrentAmps="{Binding BatCurrent}"
          CustomItemsText="{Binding HudCustomText}"
          WindDir="{Binding WindDir}"
          WindVel="{Binding WindVel}"
          Aoa="{Binding Aoa}"
          Ssa="{Binding Ssa}"
          XTrackError="{Binding XTrackError}"
          TurnRate="{Binding TurnRate}"
          BatteryVoltage2="{Binding BatteryVoltage2}"
          BatteryRemaining2="{Binding BatteryRemaining2}"
          CurrentAmps2="{Binding BatCurrent2}"
          ThrottlePercent="{Binding ThrottlePercent}"
          Failsafe="{Binding Failsafe}"
          SafetyActive="{Binding SafetyActive}"
          LinkQuality="{Binding LinkQuality}"
          TargetAlt="{Binding TargetAlt}"
          TargetSpeed="{Binding TargetSpeed}"
          DisplayHeading="{Binding HudHeading}"
          DisplaySpeed="{Binding HudSpeed}"
          DisplayAlt="{Binding HudAlt}"
          DisplayRollPitch="{Binding HudRollPitch}"
          DisplayGps="{Binding HudGps}"
          DisplayBattery="{Binding HudBattery}"
          DisplayBattery2="{Binding HudBattery2}"
          DisplayAoa="{Binding HudAoa}"
          DisplayXTrack="{Binding HudXTrack}"
          DisplayConnection="{Binding HudConnection}"
          DisplayEkf="{Binding HudEkf}"
          DisplayVibe="{Binding HudVibe}"
          DisplayPrearm="{Binding HudPrearm}"
        >
          <ctl:HudControl.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Video">
                <MenuItem Header="Record Hud to AVI" Command="{Binding RecordVideoCommand}" />
                <MenuItem Header="Stop Record" Command="{Binding StopVideoCommand}" />
                <MenuItem Header="Set MJPEG source" Command="{Binding SetVideoSourceCommand}"
                          CommandParameter="mjpeg" />
                <MenuItem Header="Start Camera" Command="{Binding SetVideoSourceCommand}"
                          CommandParameter="camera" />
                <MenuItem Header="Set GStreamer Source" Command="{Binding SetVideoSourceCommand}"
                          CommandParameter="gstreamer" />
                <MenuItem Header="HereLink Video" Command="{Binding SetVideoSourceCommand}"
                          CommandParameter="herelink" />
                <MenuItem Header="GStreamer Stop" Command="{Binding StopVideoCommand}" />
              </MenuItem>
              <MenuItem Header="Set Aspect Ratio" Command="{Binding SetAspectRatioCommand}" />
              <MenuItem Header="User Items" Command="{Binding HudUserItemsCommand}" />
              <MenuItem Header="Russian Hud" ToggleType="CheckBox" IsChecked="{Binding HudRussian, Mode=TwoWay}" />
              <MenuItem Header="Swap With Map" Command="{Binding SwapHudMapCommand}" />
              <MenuItem Header="Ground Color" Command="{Binding SetGroundColorCommand}" />
              <MenuItem Header="Battery Cell Voltage" Command="{Binding SetBatteryCellsCommand}" />
              <MenuItem Header="Show icons" ToggleType="CheckBox" IsChecked="{Binding HudShowIcons, Mode=TwoWay}" />
              <MenuItem Header="Herelink Video">
                <MenuItem Header="HereLink Video" Command="{Binding SetVideoSourceCommand}"
                          CommandParameter="herelink" />
              </MenuItem>
              <MenuItem Header="HUD Items">
                <MenuItem Header="Heading" ToggleType="CheckBox" IsChecked="{Binding HudHeading, Mode=TwoWay}" />
                <MenuItem Header="Speed" ToggleType="CheckBox" IsChecked="{Binding HudSpeed, Mode=TwoWay}" />
                <MenuItem Header="Alt" ToggleType="CheckBox" IsChecked="{Binding HudAlt, Mode=TwoWay}" />
                <MenuItem Header="Connection" ToggleType="CheckBox" IsChecked="{Binding HudConnection, Mode=TwoWay}" />
                <MenuItem Header="X-Track" ToggleType="CheckBox" IsChecked="{Binding HudXTrack, Mode=TwoWay}" />
                <MenuItem Header="Roll/Pitch" ToggleType="CheckBox" IsChecked="{Binding HudRollPitch, Mode=TwoWay}" />
                <MenuItem Header="GPS" ToggleType="CheckBox" IsChecked="{Binding HudGps, Mode=TwoWay}" />
                <MenuItem Header="Battery" ToggleType="CheckBox" IsChecked="{Binding HudBattery, Mode=TwoWay}" />
                <MenuItem Header="Battery2" ToggleType="CheckBox" IsChecked="{Binding HudBattery2, Mode=TwoWay}" />
                <MenuItem Header="EKF" ToggleType="CheckBox" IsChecked="{Binding HudEkf, Mode=TwoWay}" />
                <MenuItem Header="Vibe" ToggleType="CheckBox" IsChecked="{Binding HudVibe, Mode=TwoWay}" />
                <MenuItem Header="Prearm Status" ToggleType="CheckBox" IsChecked="{Binding HudPrearm, Mode=TwoWay}" />
                <MenuItem Header="AOA" ToggleType="CheckBox" IsChecked="{Binding HudAoa, Mode=TwoWay}" />
              </MenuItem>
            </ContextMenu>
          </ctl:HudControl.ContextMenu>
        </ctl:HudControl>
      </Border>

      <GridSplitter Grid.Row="1" Background="#262728" ResizeDirection="Rows" />

      <TabControl Grid.Row="2" Background="#434445">
        <TabItem Header="Quick">
          <!-- Grid of QuickView cells; double-click a cell to pick which cs field it shows
               (mirrors MP quickView controls + quickView_DoubleClick). -->
          <ItemsControl x:Name="QuickGrid" ItemsSource="{Binding QuickItems}" Margin="2"
                        DoubleTapped="OnQuickViewDoubleTapped">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="2" Rows="3" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:QuickItem">
                <Border Classes="qv">
                  <ctl:QuickView
                    Number="{Binding Number}"
                    Desc="{Binding Desc}"
                    NumberColor="{Binding Brush}"
                  />
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </TabItem>

        <TabItem Header="Actions">
          <!-- 5 equal star columns + uniform cells: every button/combo same size and
               reflows automatically as the panel resizes (mirrors MP TableLayoutPanel). -->
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="6" ColumnDefinitions="*,*,*,*,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="3" RowSpacing="3">
              <Grid.Styles>
                <Style Selector="Button">
                  <Setter Property="FontSize" Value="11" />
                  <Setter Property="Padding" Value="2,3" />
                  <Setter Property="MinHeight" Value="28" />
                  <Setter Property="HorizontalAlignment" Value="Stretch" />
                  <Setter Property="VerticalAlignment" Value="Stretch" />
                  <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
                <Style Selector="ComboBox">
                  <Setter Property="FontSize" Value="11" />
                  <Setter Property="HorizontalAlignment" Value="Stretch" />
                  <Setter Property="MinHeight" Value="28" />
                </Style>
                <Style Selector="NumericUpDown">
                  <Setter Property="FontSize" Value="11" />
                  <Setter Property="MinWidth" Value="0" />
                </Style>
              </Grid.Styles>

              <!-- Row 0 -->
              <ComboBox Grid.Row="0" Grid.Column="0" ItemsSource="{Binding Actions}"
                        SelectedItem="{Binding SelectedAction}" />
              <Button Grid.Row="0" Grid.Column="1" Content="Do Action" Command="{Binding DoActionCommand}" />
              <Button Grid.Row="0" Grid.Column="2" Content="Auto" Command="{Binding QuickAutoCommand}" />
              <Button Grid.Row="0" Grid.Column="3" Content="Set Home Alt" Command="{Binding SetHomeCommand}" />
              <DockPanel Grid.Row="0" Grid.Column="4">
                <NumericUpDown DockPanel.Dock="Right" Width="74" ShowButtonSpinner="False" FormatString="0.0"
                               Value="{Binding ChangeSpeedValue}" />
                <Button Content="Speed" Command="{Binding ChangeSpeedCommand}" />
              </DockPanel>

              <!-- Row 1 -->
              <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding WpNumbers}"
                        SelectedItem="{Binding SetWpIndex}" />
              <Button Grid.Row="1" Grid.Column="1" Content="Set WP" Command="{Binding SetWpCommand}" />
              <Button Grid.Row="1" Grid.Column="2" Content="Loiter" Command="{Binding QuickLoiterCommand}" />
              <Button Grid.Row="1" Grid.Column="3" Content="Restart Mission"
                      Command="{Binding RestartMissionCommand}" />
              <DockPanel Grid.Row="1" Grid.Column="4">
                <NumericUpDown DockPanel.Dock="Right" Width="74" ShowButtonSpinner="False" FormatString="0.0"
                               Value="{Binding ChangeAltValue}" />
                <Button Content="Alt" Command="{Binding ChangeAltCommand}" />
              </DockPanel>

              <!-- Row 2 -->
              <ComboBox Grid.Row="2" Grid.Column="0" ItemsSource="{Binding Modes}"
                        SelectedItem="{Binding SelectedMode}" />
              <Button Grid.Row="2" Grid.Column="1" Content="Set Mode" Command="{Binding SetModeCommand}" />
              <Button Grid.Row="2" Grid.Column="2" Content="RTL" Command="{Binding QuickRtlCommand}" />
              <Button Grid.Row="2" Grid.Column="3" Content="Raw Sensor View"
                      Command="{Binding RawSensorViewCommand}" />
              <DockPanel Grid.Row="2" Grid.Column="4">
                <NumericUpDown DockPanel.Dock="Right" Width="74" ShowButtonSpinner="False" FormatString="0"
                               Value="{Binding LoiterRadValue}" />
                <Button Content="Loiter Rad" Command="{Binding SetLoiterRadCommand}" />
              </DockPanel>

              <!-- Row 3 -->
              <ComboBox Grid.Row="3" Grid.Column="0" ItemsSource="{Binding MountModes}"
                        SelectedItem="{Binding SelectedMountMode}" />
              <Button Grid.Row="3" Grid.Column="1" Content="Set Mount" Command="{Binding SetMountCommand}" />
              <Button Grid.Row="3" Grid.Column="2" Content="Joystick" Command="{Binding JoystickCommand}" />
              <Button Grid.Row="3" Grid.Column="3" Content="Arm/ Disarm" Command="{Binding ToggleArmCommand}" />
              <Button Grid.Row="3" Grid.Column="4" Content="Clear Track" Command="{Binding ClearTrackCommand}" />

              <!-- Row 4 -->
              <Button Grid.Row="4" Grid.Column="2" Content="Message" Command="{Binding ShowMessageCommand}" />
              <Button Grid.Row="4" Grid.Column="3" Content="Resume Mission"
                      Command="{Binding ResumeMissionCommand}" />
              <Button Grid.Row="4" Grid.Column="4" Content="Abort Landing"
                      Command="{Binding AbortLandCommand}" />
            </Grid>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Messages">
          <TextBox
            Text="{Binding StatusText}"
            AcceptsReturn="True"
            IsReadOnly="True"
            TextWrapping="Wrap"
            Background="#1F1F20"
            Foreground="WhiteSmoke"
          />
        </TabItem>

        <TabItem Header="PreFlight">
          <DockPanel Margin="6">
            <Button DockPanel.Dock="Top" HorizontalAlignment="Right" Content="Edit" Width="60"
                    Command="{Binding EditPreflightCommand}" />
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding PreflightChecks}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CheckItem">
                    <Grid ColumnDefinitions="*,120,28" Margin="0,2" Background="#3A3B3C">
                      <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="6,4"
                                 VerticalAlignment="Center" />
                      <Panel Grid.Column="1">
                        <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Foreground="#94C11F"
                                   IsVisible="{Binding Ok}" />
                        <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Foreground="#E03030"
                                   IsVisible="{Binding !Ok}" />
                      </Panel>
                      <!-- manual items are user-checkable; auto items reflect telemetry read-only -->
                      <CheckBox Grid.Column="2" IsChecked="{Binding Ok, Mode=TwoWay}"
                                IsHitTestVisible="{Binding Manual}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </TabItem>

        <TabItem Header="Gauges">
          <!-- Double-click a gauge to set its Min/Max; persisted via Settings (mirrors
               Gspeed_DoubleClick). The Heading cell is an HSI (cs.yaw/nav_bearing/wp_dist). -->
          <Grid Margin="6" RowDefinitions="*,*" ColumnDefinitions="*,*">
            <ctl:Gauge x:Name="GVsi" Grid.Row="0" Grid.Column="0" Margin="6" MinHeight="120"
                       Label="VSI" Units="m/s" Min="-10" Max="10" Value="{Binding VerticalSpeed}"
                       DoubleTapped="OnGaugeDoubleTapped" />
            <ctl:Gauge x:Name="GSpeed" Grid.Row="0" Grid.Column="1" Margin="6" MinHeight="120"
                       Label="Speed" Units="m/s" Min="0" Max="60" Value="{Binding AirSpeed}"
                       Value2="{Binding GroundSpeed}" DoubleTapped="OnGaugeDoubleTapped" />
            <ctl:Gauge x:Name="GAlt" Grid.Row="1" Grid.Column="0" Margin="6" MinHeight="120"
                       Label="Alt" Units="m" Min="0" Max="1000" Value="{Binding Alt}"
                       DoubleTapped="OnGaugeDoubleTapped" />
            <ctl:Hsi Grid.Row="1" Grid.Column="1" Margin="6" MinHeight="120"
                     Heading="{Binding Yaw}" NavHeading="{Binding NavBearing}"
                     WpDist="{Binding WpDist}" />
          </Grid>
        </TabItem>

        <TabItem Header="Status">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Statuses}" Margin="6">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:StatusItem">
                  <Grid Width="200" ColumnDefinitions="*,Auto" Margin="2,1">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#BBBBBB" FontSize="11" />
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Servo/Relay">
          <!-- horizontal wrap: rows reflow into as many columns as the width allows,
               vertical scroll for overflow (mirrors MP FlowLayoutPanel). -->
          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ServoRelayItems}" Margin="4">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.DataTemplates>
                <DataTemplate DataType="vm:ServoChannel">
                  <StackPanel Orientation="Horizontal" Spacing="2" Margin="2,1" Width="316">
                    <Button Content="Low" Width="38" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetServoChannelCommand}"
                            CommandParameter="{Binding Number, StringFormat='{}{0}:low'}" />
                    <Button Content="Mid" Width="38" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetServoChannelCommand}"
                            CommandParameter="{Binding Number, StringFormat='{}{0}:mid'}" />
                    <Button Content="High" Width="38" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetServoChannelCommand}"
                            CommandParameter="{Binding Number, StringFormat='{}{0}:high'}" />
                    <Button Content="Toggle" Width="48" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetServoChannelCommand}"
                            CommandParameter="{Binding Number, StringFormat='{}{0}:toggle'}" />
                    <Border Background="#5A5A5A" Width="40" Margin="4,0,0,0">
                      <TextBlock Text="{Binding Number}" Foreground="White" FontSize="11"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBox Width="42" FontSize="11" Padding="2,1" Text="{Binding Min}" />
                    <TextBox Width="42" FontSize="11" Padding="2,1" Text="{Binding Max}" />
                  </StackPanel>
                </DataTemplate>
                <DataTemplate DataType="vm:RelayChannel">
                  <StackPanel Orientation="Horizontal" Spacing="2" Margin="2,1" Width="316">
                    <Button Content="Low" Width="38" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetRelayCommand}"
                            CommandParameter="{Binding Index, StringFormat='{}{0}:low'}" />
                    <Button Content="High" Width="38" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetRelayCommand}"
                            CommandParameter="{Binding Index, StringFormat='{}{0}:high'}" />
                    <Button Content="Toggle" Width="48" FontSize="11" Padding="2,2"
                            Command="{Binding $parent[ItemsControl].((vm:FlightDataViewModel)DataContext).SetRelayCommand}"
                            CommandParameter="{Binding Index, StringFormat='{}{0}:toggle'}" />
                    <Border Background="#5A5A5A" Width="86" Margin="4,0,0,0">
                      <TextBlock Text="{Binding Label}" Foreground="White" FontSize="11"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.DataTemplates>
            </ItemsControl>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Scripts">
          <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,*,Auto,*">
            <TextBlock Grid.Row="0" Text="{Binding ScriptStatus, StringFormat=Lua Script Status: {0}}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="1" Text="{Binding SelectedScript, StringFormat=Selected Lua Script: {0}}" />
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,4">
              <Button Content="Select Lua Script" Command="{Binding SelectScriptCommand}" />
              <Button Content="Edit Selected" Command="{Binding EditScriptCommand}"
                      IsVisible="{Binding ScriptSelected}" />
              <Button Content="Run" Command="{Binding RunScriptCommand}" />
              <Button Content="Abort" Command="{Binding AbortScriptCommand}" />
            </StackPanel>
            <TextBox Grid.Row="3" Text="{Binding ScriptEditorText}" AcceptsReturn="True"
                     AcceptsTab="True" FontFamily="Consolas,Menlo,monospace" FontSize="12"
                     Background="#1F1F20" Foreground="WhiteSmoke"
                     Watermark="Lua code (leave empty to run the selected file)" />
            <TextBlock Grid.Row="4" Text="Output" Margin="0,6,0,2" />
            <TextBox Grid.Row="5" Text="{Binding ScriptOutput}" AcceptsReturn="True" IsReadOnly="True"
                     TextWrapping="Wrap" FontFamily="Consolas,Menlo,monospace" FontSize="12"
                     Background="#1F1F20" Foreground="#9BD" />
          </Grid>
        </TabItem>

        <TabItem Header="Payload Control">
          <Grid Margin="10" ColumnDefinitions="Auto,*" RowDefinitions="*">
            <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,20,0">
              <TextBlock Text="Tilt" HorizontalAlignment="Center" />
              <Slider Orientation="Vertical" Height="160" Minimum="-90" Maximum="45"
                      Value="{Binding Tilt, Mode=TwoWay}" HorizontalAlignment="Center" />
              <Button Content="Reset Position" FontSize="11" Command="{Binding ResetPositionCommand}" />
              <Button Content="Video Control" FontSize="11" Command="{Binding TriggerCameraCommand}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="14" VerticalAlignment="Top">
              <StackPanel Spacing="2">
                <TextBlock Text="Pan" />
                <Slider Minimum="-180" Maximum="180" Value="{Binding Pan, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="Roll" />
                <Slider Minimum="-90" Maximum="90" Value="{Binding Roll2, Mode=TwoWay}" />
              </StackPanel>
            </StackPanel>
          </Grid>
        </TabItem>

        <TabItem Header="Telemetry Logs">
          <Grid Margin="8" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto"
                ColumnSpacing="6" RowSpacing="6">
            <Button Grid.Row="0" Grid.Column="0" Content="Load Log" HorizontalAlignment="Stretch"
                    Command="{Binding LoadTlogCommand}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LogStatus}" Foreground="#C8A03C"
                       VerticalAlignment="Center" TextWrapping="Wrap" />

            <Button Grid.Row="1" Grid.Column="0" Content="Play/Pause" HorizontalAlignment="Stretch"
                    Command="{Binding PlayPauseTlogCommand}" />
            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100"
                    Value="{Binding TlogProgress, Mode=TwoWay}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding TlogPositionText}"
                       VerticalAlignment="Center" />

            <Button Grid.Row="2" Grid.Column="0" Content="Tlog > Kml or Graph"
                    HorizontalAlignment="Stretch" Command="{Binding TlogToKmlCommand}" />
            <WrapPanel Grid.Row="2" Grid.Column="1">
              <Button Content="10x" Margin="1" MinWidth="36"
                      Command="{Binding SetTlogSpeedCommand}" CommandParameter="10" />
              <Button Content="5x" Margin="1" MinWidth="36"
                      Command="{Binding SetTlogSpeedCommand}" CommandParameter="5" />
              <Button Content="2x" Margin="1" MinWidth="36"
                      Command="{Binding SetTlogSpeedCommand}" CommandParameter="2" />
              <Button Content="1x" Margin="1" MinWidth="36"
                      Command="{Binding SetTlogSpeedCommand}" CommandParameter="1" />
              <Button Content="0.5" Margin="1" MinWidth="36"
                      Command="{Binding SetTlogSpeedCommand}" CommandParameter="0.5" />
              <Button Content="0.25" Margin="1" MinWidth="36"
                      Command="{Binding SetTlogSpeedCommand}" CommandParameter="0.25" />
              <Button Content="0.1" Margin="1" MinWidth="36"
                      Command="{Binding SetTlogSpeedCommand}" CommandParameter="0.1" />
            </WrapPanel>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding PlaybackSpeedText}"
                       VerticalAlignment="Center" />
          </Grid>
        </TabItem>

        <TabItem Header="DataFlash Logs">
          <Grid Margin="8" ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto"
                ColumnSpacing="4" RowSpacing="4">
            <Button Grid.Row="0" Grid.Column="0" Content="Download DataFlash Log Via Mavlink"
                    HorizontalAlignment="Stretch" Command="{Binding DownloadDataflashLogCommand}" />
            <Button Grid.Row="0" Grid.Column="1" Content="Review a Log" HorizontalAlignment="Stretch"
                    Command="{Binding ReviewLogCommand}" />
            <Button Grid.Row="0" Grid.Column="2" Content="Auto Analysis" HorizontalAlignment="Stretch"
                    Command="{Binding AutoAnalysisCommand}" />

            <Button Grid.Row="1" Grid.Column="0" Content="Create KML + gpx" HorizontalAlignment="Stretch"
                    Command="{Binding CreateKmlGpxCommand}" />
            <Button Grid.Row="1" Grid.Column="1" Content="Convert Bin to Log" HorizontalAlignment="Stretch"
                    Command="{Binding ConvertBinToLogCommand}" />
            <Button Grid.Row="1" Grid.Column="2" Content="Create Matlab File" HorizontalAlignment="Stretch"
                    Command="{Binding CreateMatlabCommand}" />

            <Button Grid.Row="2" Grid.Column="0" Content="Geo Reference Images" HorizontalAlignment="Stretch"
                    Command="{Binding GeoReferenceImagesCommand}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding LogStatus}"
                       Foreground="#C8A03C" TextWrapping="Wrap" VerticalAlignment="Center" />
          </Grid>
        </TabItem>

        <TabItem Header="Transponder">
          <StackPanel Margin="10" Spacing="8">
            <Button Content="Connect to Transponder" HorizontalAlignment="Left"
                    Command="{Binding ConnectTransponderCommand}" />
            <TextBlock Text="{Binding TransponderStatus}" Foreground="#94C11F" />
            <Grid ColumnDefinitions="Auto,160" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Squawk" VerticalAlignment="Center" />
              <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="7777"
                             Value="{Binding Squawk, Mode=TwoWay}" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="FlightID" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" MaxLength="8" Text="{Binding FlightId, Mode=TwoWay}" />
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="STBY" Width="60" Command="{Binding TransponderStandbyCommand}" />
              <Button Content="ALT" Width="60" Command="{Binding TransponderAltCommand}" />
              <Button Content="ON" Width="60" Command="{Binding TransponderOnCommand}" />
              <Button Content="IDENT" Width="60" Command="{Binding TransponderIdentCommand}" />
            </StackPanel>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Mode" FontWeight="Bold" />
                <CheckBox Content="Mode A" IsChecked="{Binding ModeA, Mode=TwoWay}" />
                <CheckBox Content="Mode C" IsChecked="{Binding ModeC, Mode=TwoWay}" />
                <CheckBox Content="Mode S" IsChecked="{Binding ModeS, Mode=TwoWay}" />
                <CheckBox Content="1090ES ADS-B OUT" IsChecked="{Binding ModeEs, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="Faults" FontWeight="Bold" />
                <CheckBox Content="Maint. Req." IsEnabled="False" />
                <CheckBox Content="GPS Unavail." IsEnabled="False" />
                <CheckBox Content="GPS No Fix" IsEnabled="False" />
                <CheckBox Content="TX Sys. Fail." IsEnabled="False" />
                <CheckBox Content="On Ground" IsEnabled="False" />
              </StackPanel>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="16">
              <TextBlock Text="NIC: 0" />
              <TextBlock Text="NACp: 0" />
            </StackPanel>
          </StackPanel>
        </TabItem>

        <TabItem Header="Aux Function">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding AuxOptions}" Margin="6">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AuxRow">
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                    <Border Background="#5A5A5A" Width="40">
                      <TextBlock Text="{Binding Channel}" Foreground="White" FontSize="11"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ComboBox Width="240" IsVisible="{Binding Field.IsCombo}"
                              ItemsSource="{Binding Field.Options}"
                              SelectedItem="{Binding Field.SelectedOption}" />
                    <NumericUpDown Width="240" IsVisible="{Binding Field.IsNumeric}"
                                   Value="{Binding Field.Value}" FormatString="0" />
                    <TextBlock Text="{Binding Field.Status}" VerticalAlignment="Center"
                               Foreground="#94C11F" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>

    <GridSplitter Grid.Column="1" Background="#262728" ResizeDirection="Columns" />

    <Border Grid.Column="{Binding MapColumn}" Background="#262728" ClipToBounds="True">
      <Grid>
        <ctl:MapView x:Name="FdMap" />

        <!-- top-left controls: Auto Pan + Clear Track -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
          <CheckBox Content="Auto Pan" IsChecked="{Binding AutoPan}" Foreground="White" />
          <Button Content="Clear Track" Command="{Binding ClearTrackCommand}" Padding="6,2" />
        </StackPanel>

        <!-- bottom-left live readouts (mirrors lbl_hdop / lbl_sats / dist) -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8"
                Background="#99000000" CornerRadius="4" Padding="6,3">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Foreground="White" Text="{Binding SatCount, StringFormat='Sats: {0}'}" />
            <TextBlock Foreground="White" Text="{Binding GpsHdop, StringFormat='hdop: {0:0.0}'}" />
            <TextBlock Foreground="White" Text="{Binding DistToHome, StringFormat='Home: {0:0} m'}" />
          </StackPanel>
        </Border>

        <!-- bottom-right legend -->
        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8"
                   Foreground="#CCCCCC" FontSize="11" Text="GPS Track (Black)" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
