<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  mc:Ignorable="d"
  d:DesignWidth="800"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.ActionPageView"
  x:DataType="vm:ActionPageViewModel"
  Background="#434445"
>
  <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16">
    <TextBlock Grid.Row="0" Classes="pagetitle" Text="{Binding Title}" />
    <TextBlock
      Grid.Row="1"
      Text="{Binding Instructions}"
      Classes="fieldlbl"
      TextWrapping="Wrap"
      MaxWidth="640"
      HorizontalAlignment="Left"
      Margin="0,0,0,12"
    />
    <ItemsControl Grid.Row="2" ItemsSource="{Binding Actions}" Margin="0,0,0,12">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:ActionItem">
          <Button Content="{Binding Label}" Command="{Binding Command}" Margin="0,0,8,8" />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
    <Border Grid.Row="3" Background="Black" BorderBrush="#262728" BorderThickness="1">
      <ScrollViewer>
        <TextBlock
          Text="{Binding Log}"
          Foreground="#94C11F"
          FontFamily="Consolas,Menlo,monospace"
          FontSize="12"
          Padding="8"
          TextWrapping="Wrap"
        />
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
