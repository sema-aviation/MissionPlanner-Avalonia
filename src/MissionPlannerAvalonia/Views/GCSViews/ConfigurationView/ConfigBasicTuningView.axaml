<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  mc:Ignorable="d"
  d:DesignWidth="700"
  d:DesignHeight="700"
  x:Class="MissionPlannerAvalonia.Views.GCSViews.ConfigurationView.ConfigBasicTuningView"
  x:DataType="cv:ConfigBasicTuningViewModel"
  Background="#434445"
>
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16">
    <TextBlock Grid.Row="0" Classes="pagetitle" Text="{Binding Title}" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
      <Button Content="Refresh" Command="{Binding RefreshCommand}" />
    </StackPanel>

    <ScrollViewer Grid.Row="2">
      <ItemsControl ItemsSource="{Binding Items}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="cv:SimplePidItem">
            <Border
              BorderBrush="#5A5A5A"
              BorderThickness="1"
              CornerRadius="4"
              Margin="0,4"
              Padding="10"
            >
              <StackPanel Spacing="4">
                <TextBlock
                  Text="{Binding Title}"
                  FontWeight="Bold"
                  Foreground="#D8D8D8"
                />
                <TextBlock
                  Text="{Binding Description}"
                  Classes="fieldlbl"
                  TextWrapping="Wrap"
                />
                <Grid ColumnDefinitions="*,90">
                  <Slider
                    Grid.Column="0"
                    Minimum="{Binding Min}"
                    Maximum="{Binding Max}"
                    SmallChange="{Binding Increment}"
                    Value="{Binding Value}"
                    VerticalAlignment="Center"
                  />
                  <NumericUpDown
                    Grid.Column="1"
                    Value="{Binding Value}"
                    Minimum="{Binding Min}"
                    Maximum="{Binding Max}"
                    Increment="{Binding Increment}"
                    FormatString="0.######"
                    VerticalAlignment="Center"
                  />
                </Grid>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <TextBox
      Grid.Row="3"
      Text="{Binding Info}"
      IsReadOnly="True"
      AcceptsReturn="True"
      TextWrapping="Wrap"
      Height="90"
      Margin="0,8,0,0"
      Background="#2E2F30"
      Foreground="#D8D8D8"
    />

    <TextBlock
      Grid.Row="4"
      Text="{Binding Note}"
      Foreground="#E0A030"
      TextWrapping="Wrap"
      Margin="0,8,0,0"
    />
  </Grid>
</UserControl>
