<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  mc:Ignorable="d"
  d:DesignWidth="520"
  d:DesignHeight="360"
  x:Class="MissionPlannerAvalonia.Views.GCSViews.ConfigurationView.ConfigHWCANView"
  x:DataType="cv:ConfigHWCANViewModel"
  Background="{DynamicResource MpControlBg}"
>
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="8">
      <TextBlock Classes="pagetitle" Text="CAN" />

      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <TextBlock Text="Enable CAN" Classes="fieldlbl" VerticalAlignment="Center" Width="120" />
        <ComboBox
          MinWidth="200"
          ItemsSource="{Binding CanEnableOptions}"
          SelectedItem="{Binding SelectedCanEnable}"
        />
      </StackPanel>

      <TextBlock
        Text="NOTE: a restart is required after changing this option"
        Classes="fieldlbl"
        TextWrapping="Wrap"
        Margin="0,2,0,8"
      />

      <Border BorderBrush="{DynamicResource MpBg}" BorderThickness="1" Padding="12">
        <StackPanel Spacing="8">
          <Button Content="Start Enumeration" Command="{Binding StartEnumerationCommand}" Width="200" />
          <Button Content="Stop Enumeration" Command="{Binding StopEnumerationCommand}" Width="200" />
          <Button Content="Save All Config" Command="{Binding SaveConfigCommand}" Width="200" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <CheckBox Content="Factory Reset" IsChecked="{Binding FactoryResetArmed}" Foreground="#DDDDDD" />
            <Button Content="Reset config" Command="{Binding FactoryResetCommand}" Width="200" />
          </StackPanel>
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding Status}" Classes="fieldlbl" Margin="0,4,0,0" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
