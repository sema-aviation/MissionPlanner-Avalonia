<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  mc:Ignorable="d"
  d:DesignWidth="800"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.GCSViews.ConfigurationView.ConfigAccelCalibrationView"
  x:DataType="cv:ConfigAccelCalibrationViewModel"
  Background="#434445"
>
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="16">
    <TextBlock Grid.Row="0" Classes="pagetitle" Text="{Binding Title}" />

    <TextBlock
      Grid.Row="1"
      Text="{Binding Instructions}"
      Classes="fieldlbl"
      TextWrapping="Wrap"
      Margin="0,8,0,12"
    />

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
      <Button
        Content="{Binding AccelButtonText}"
        Command="{Binding CalibrateAccelCommand}"
        IsEnabled="{Binding AccelButtonEnabled}"
        MinWidth="150"
      />
      <Button Content="{Binding LevelButtonText}" Command="{Binding CalibrateLevelCommand}" MinWidth="130" />
      <Button Content="{Binding SimpleButtonText}" Command="{Binding SimpleAccelCommand}" MinWidth="130" />
    </StackPanel>

    <Border
      Grid.Row="3"
      Background="#2D2D2D"
      CornerRadius="4"
      Padding="12"
      Margin="0,12,0,0"
      MinHeight="48"
    >
      <TextBlock
        Text="{Binding UserMessage}"
        Foreground="#94C11F"
        FontSize="18"
        TextWrapping="Wrap"
        VerticalAlignment="Center"
      />
    </Border>

    <TextBox
      Grid.Row="4"
      Text="{Binding Log}"
      IsReadOnly="True"
      AcceptsReturn="True"
      TextWrapping="Wrap"
      Margin="0,12,0,0"
    />
  </Grid>
</UserControl>
