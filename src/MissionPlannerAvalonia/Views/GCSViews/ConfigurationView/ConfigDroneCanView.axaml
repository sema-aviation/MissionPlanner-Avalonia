<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  mc:Ignorable="d"
  d:DesignWidth="800"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.GCSViews.ConfigurationView.ConfigDroneCanView"
  x:DataType="cv:ConfigDroneCanViewModel"
  Background="#434445"
>
  <Grid RowDefinitions="Auto,Auto,Auto,2*,Auto,Auto,Auto,3*" Margin="16">
    <TextBlock Grid.Row="0" Classes="pagetitle" Text="DroneCAN / UAVCAN" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
      <ComboBox
        ItemsSource="{Binding BusOptions}"
        SelectedIndex="{Binding SelectedBusIndex}"
        Width="160"
        MinHeight="28"
      />
      <Button Content="{Binding ConnectLabel}" Command="{Binding ToggleConnectCommand}" />
      <Button Content="Refresh" Command="{Binding RefreshCommand}" />
      <Button Name="BusInspectorBtn" Content="Bus Inspector" />
    </StackPanel>

    <TextBlock
      Grid.Row="2"
      Text="{Binding Status}"
      Classes="fieldlbl"
      TextWrapping="Wrap"
      Margin="0,0,0,8"
    />

    <DataGrid
      Grid.Row="3"
      ItemsSource="{Binding Nodes}"
      SelectedItem="{Binding SelectedNode}"
      AutoGenerateColumns="False"
      IsReadOnly="True"
      GridLinesVisibility="All"
      HeadersVisibility="Column"
    >
      <DataGrid.Columns>
        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
        <DataGridTextColumn Header="Health" Binding="{Binding Health}" Width="100" />
        <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="140" />
        <DataGridTextColumn Header="Uptime" Binding="{Binding Uptime}" Width="120" />
        <DataGridTextColumn Header="SW" Binding="{Binding SoftwareVersion}" Width="120" />
        <DataGridTextColumn Header="HW" Binding="{Binding HardwareVersion}" Width="80" />
      </DataGrid.Columns>
    </DataGrid>

    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" Margin="0,8,0,4">
      <Button Content="Get Parameters" Command="{Binding GetParametersCommand}" />
      <Button Content="Restart Node" Command="{Binding RestartNodeCommand}" />
      <Button Name="FirmwareUpdateBtn" Content="Update Firmware…" />
      <Button Content="Write" Command="{Binding WriteParametersCommand}" />
      <Button Content="Save to Flash" Command="{Binding SaveConfigCommand}" />
      <Button Content="Erase" Command="{Binding EraseConfigCommand}" />
    </StackPanel>

    <TextBlock
      Grid.Row="5"
      Text="{Binding NodeStatus}"
      Classes="fieldlbl"
      TextWrapping="Wrap"
      Margin="0,0,0,8"
    />

    <DataGrid
      Grid.Row="7"
      ItemsSource="{Binding NodeParams}"
      AutoGenerateColumns="False"
      GridLinesVisibility="All"
      HeadersVisibility="Column"
    >
      <DataGrid.Columns>
        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" IsReadOnly="True" />
        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" IsReadOnly="False" />
        <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="*" IsReadOnly="True" />
        <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="*" IsReadOnly="True" />
        <DataGridTextColumn Header="Default" Binding="{Binding Default}" Width="*" IsReadOnly="True" />
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
