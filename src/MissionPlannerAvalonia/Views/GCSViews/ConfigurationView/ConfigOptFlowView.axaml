<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  mc:Ignorable="d"
  d:DesignWidth="800"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.GCSViews.ConfigurationView.ConfigOptFlowView"
  x:DataType="cv:ConfigOptFlowViewModel"
  Background="#434445"
>
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="10">
      <TextBlock Classes="pagetitle" Text="Optical Flow" />
      <Button Content="Refresh Params" Command="{Binding RefreshCommand}" HorizontalAlignment="Left" />

      <!-- Legacy panel (older firmware exposes FLOW_ENABLE) -->
      <StackPanel IsVisible="{Binding LegacyPanelVisible}" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
        <CheckBox Content="Enable" IsChecked="{Binding Enable.Checked}" />
        <TextBlock Text="{Binding Enable.Status}" Foreground="#94C11F" VerticalAlignment="Center" />
      </StackPanel>

      <!-- New panel -->
      <StackPanel IsVisible="{Binding NewPanelVisible}" Spacing="10">
        <Grid ColumnDefinitions="220,200,Auto,*" RowDefinitions="Auto,Auto" Margin="0,6,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="Type" VerticalAlignment="Center" Margin="0,0,8,4" />
          <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="180" ItemsSource="{Binding Type.Options}" SelectedItem="{Binding Type.SelectedOption}" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Type.Status}" Foreground="#94C11F" VerticalAlignment="Center" Margin="8,0" />

          <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldlbl" Text="Yaw Orientation" VerticalAlignment="Center" Margin="0,0,8,4" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" MinWidth="180" Value="{Binding Yaw.Value}" Minimum="-179" Maximum="180" Increment="1" FormatString="0.######" />
          <TextBlock Grid.Row="1" Grid.Column="2" Classes="fieldlbl" Text="degrees, relative to vehicle" VerticalAlignment="Center" Margin="8,0" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Yaw.Status}" Foreground="#94C11F" VerticalAlignment="Center" Margin="8,0" />
        </Grid>

        <TextBlock Classes="fieldlbl" Text="Scaling Factors" FontWeight="Bold" />
        <Grid ColumnDefinitions="220,200,Auto,*" RowDefinitions="Auto,Auto" Margin="0,2,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="FX Scale" VerticalAlignment="Center" Margin="0,0,8,4" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" MinWidth="180" Value="{Binding FxScaler.Value}" Minimum="-200" Maximum="200" Increment="1" FormatString="0.######" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding FxScaler.Status}" Foreground="#94C11F" VerticalAlignment="Center" Margin="8,0" />

          <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldlbl" Text="FY Scale" VerticalAlignment="Center" Margin="0,0,8,4" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" MinWidth="180" Value="{Binding FyScaler.Value}" Minimum="-200" Maximum="200" Increment="1" FormatString="0.######" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding FyScaler.Status}" Foreground="#94C11F" VerticalAlignment="Center" Margin="8,0" />
        </Grid>

        <TextBlock Classes="fieldlbl" Text="Position of Sensor, relative to IMU" FontWeight="Bold" />
        <Grid ColumnDefinitions="220,200,Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="Position X" VerticalAlignment="Center" Margin="0,0,8,4" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" MinWidth="180" Value="{Binding PosX.Value}" Minimum="-5" Maximum="5" Increment="0.01" FormatString="0.######" />
          <TextBlock Grid.Row="0" Grid.Column="2" Classes="fieldlbl" Text="metres foward" VerticalAlignment="Center" Margin="8,0" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding PosX.Status}" Foreground="#94C11F" VerticalAlignment="Center" Margin="8,0" />

          <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldlbl" Text="Position Y" VerticalAlignment="Center" Margin="0,0,8,4" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" MinWidth="180" Value="{Binding PosY.Value}" Minimum="-5" Maximum="5" Increment="0.01" FormatString="0.######" />
          <TextBlock Grid.Row="1" Grid.Column="2" Classes="fieldlbl" Text="metres right" VerticalAlignment="Center" Margin="8,0" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding PosY.Status}" Foreground="#94C11F" VerticalAlignment="Center" Margin="8,0" />

          <TextBlock Grid.Row="2" Grid.Column="0" Classes="fieldlbl" Text="Position Z" VerticalAlignment="Center" Margin="0,0,8,4" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" MinWidth="180" Value="{Binding PosZ.Value}" Minimum="-5" Maximum="5" Increment="0.01" FormatString="0.######" />
          <TextBlock Grid.Row="2" Grid.Column="2" Classes="fieldlbl" Text="metres down" VerticalAlignment="Center" Margin="8,0" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding PosZ.Status}" Foreground="#94C11F" VerticalAlignment="Center" Margin="8,0" />
        </Grid>

        <Grid ColumnDefinitions="220,200,Auto,*" IsVisible="{Binding HeightOverrideVisible}" Margin="0,2,0,0">
          <TextBlock Grid.Column="0" Classes="fieldlbl" Text="Height Override" VerticalAlignment="Center" Margin="0,0,8,4" />
          <NumericUpDown Grid.Column="1" MinWidth="180" Value="{Binding HeightOverride.Value}" Minimum="0" Maximum="2" Increment="0.01" FormatString="0.######" />
          <TextBlock Grid.Column="2" Classes="fieldlbl" Text="metres from ground" VerticalAlignment="Center" Margin="8,0" />
          <TextBlock Grid.Column="3" Text="{Binding HeightOverride.Status}" Foreground="#94C11F" VerticalAlignment="Center" Margin="8,0" />
        </Grid>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
