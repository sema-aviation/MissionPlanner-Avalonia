<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  mc:Ignorable="d"
  d:DesignWidth="900"
  d:DesignHeight="780"
  x:Class="MissionPlannerAvalonia.Views.GCSViews.ConfigurationView.ConfigCompassLegacyView"
  x:DataType="cv:ConfigCompassLegacyViewModel"
  Background="{DynamicResource MpControlBg}"
>
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="8">
      <TextBlock Classes="pagetitle" Text="{Binding Title}" Margin="0,0,0,4" />
      <Border Classes="titlerule" />

      <TextBlock Classes="fieldlbl" TextWrapping="Wrap" Text="{Binding Intro}" />

      <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

        <Border Grid.Column="0" Background="{DynamicResource MpInputBg}" CornerRadius="4" Padding="12">
          <StackPanel Spacing="6">
            <TextBlock Classes="fieldlbl" FontSize="15" Text="Compass 1" />
            <CheckBox Content="Use Compass" IsChecked="{Binding FieldUse1.Checked}" />
            <CheckBox Content="Externally mounted" IsChecked="{Binding FieldExternal1.Checked}" />
            <ComboBox
              MinWidth="150"
              IsVisible="{Binding FieldExternal1.Checked}"
              ItemsSource="{Binding FieldOrient1.Options}"
              SelectedItem="{Binding FieldOrient1.SelectedOption}"
            />
            <TextBlock
              Text="{Binding Compass1Offset}"
              Foreground="{Binding Compass1Brush}"
              IsVisible="{Binding FieldUse1.Checked}"
              TextWrapping="Wrap"
            />
            <TextBlock
              Text="{Binding Compass1Mot}"
              IsVisible="{Binding FieldUse1.Checked}"
              Classes="fieldlbl"
              TextWrapping="Wrap"
            />
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource MpInputBg}" CornerRadius="4" Padding="12" IsVisible="{Binding Compass2Visible}">
          <StackPanel Spacing="6">
            <TextBlock Classes="fieldlbl" FontSize="15" Text="Compass 2" />
            <CheckBox Content="Use Compass" IsChecked="{Binding FieldUse2.Checked}" />
            <CheckBox Content="Externally mounted" IsChecked="{Binding FieldExternal2.Checked}" />
            <ComboBox
              MinWidth="150"
              IsVisible="{Binding FieldExternal2.Checked}"
              ItemsSource="{Binding FieldOrient2.Options}"
              SelectedItem="{Binding FieldOrient2.SelectedOption}"
            />
            <TextBlock
              Text="{Binding Compass2Offset}"
              Foreground="{Binding Compass2Brush}"
              IsVisible="{Binding FieldUse2.Checked}"
              TextWrapping="Wrap"
            />
            <TextBlock
              Text="{Binding Compass2Mot}"
              IsVisible="{Binding FieldUse2.Checked}"
              Classes="fieldlbl"
              TextWrapping="Wrap"
            />
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="{DynamicResource MpInputBg}" CornerRadius="4" Padding="12" IsVisible="{Binding Compass3Visible}">
          <StackPanel Spacing="6">
            <TextBlock Classes="fieldlbl" FontSize="15" Text="Compass 3" />
            <CheckBox Content="Use Compass" IsChecked="{Binding FieldUse3.Checked}" />
            <CheckBox Content="Externally mounted" IsChecked="{Binding FieldExternal3.Checked}" />
            <ComboBox
              MinWidth="150"
              IsVisible="{Binding FieldExternal3.Checked}"
              ItemsSource="{Binding FieldOrient3.Options}"
              SelectedItem="{Binding FieldOrient3.SelectedOption}"
            />
            <TextBlock
              Text="{Binding Compass3Offset}"
              Foreground="{Binding Compass3Brush}"
              IsVisible="{Binding FieldUse3.Checked}"
              TextWrapping="Wrap"
            />
            <TextBlock
              Text="{Binding Compass3Mot}"
              IsVisible="{Binding FieldUse3.Checked}"
              Classes="fieldlbl"
              TextWrapping="Wrap"
            />
          </StackPanel>
        </Border>
      </Grid>

      <Border Background="{DynamicResource MpInputBg}" CornerRadius="4" Padding="12" Margin="0,4,0,0">
        <StackPanel Spacing="8">
          <TextBlock Classes="fieldlbl" FontSize="15" Text="General Compass Settings" />
          <StackPanel Orientation="Horizontal" Spacing="16">
            <CheckBox Content="Automatically learn offsets" IsChecked="{Binding FieldLearn.Checked}" />
            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasPrimary}">
              <TextBlock Classes="fieldlbl" Text="Primary Compass" VerticalAlignment="Center" />
              <ComboBox
                MinWidth="150"
                ItemsSource="{Binding FieldPrimary.Options}"
                SelectedItem="{Binding FieldPrimary.SelectedOption}"
              />
            </StackPanel>
          </StackPanel>

          <CheckBox Content="Enable automatic declination" IsChecked="{Binding FieldAutoDec.Checked}" />
          <Grid ColumnDefinitions="Auto,80,Auto,80,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0" Classes="fieldlbl" Text="Declination" VerticalAlignment="Center" />
            <NumericUpDown
              Grid.Column="1"
              IsEnabled="{Binding !FieldAutoDec.Checked}"
              Value="{Binding DeclinationDeg}"
              Increment="1"
              FormatString="0"
            />
            <TextBlock Grid.Column="2" Classes="fieldlbl" Text="deg" VerticalAlignment="Center" />
            <NumericUpDown
              Grid.Column="3"
              IsEnabled="{Binding !FieldAutoDec.Checked}"
              Value="{Binding DeclinationMin}"
              Minimum="0"
              Maximum="60"
              Increment="1"
              FormatString="0"
            />
            <Button Grid.Column="4" Content="Write Declination" Command="{Binding WriteDeclinationCommand}" />
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource MpInputBg}" CornerRadius="4" Padding="12" Margin="0,4,0,0">
        <StackPanel Spacing="8">
          <TextBlock Classes="fieldlbl" FontSize="15" Text="Onboard Mag Calibration" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Top">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Start" Command="{Binding StartMagCalCommand}" MinWidth="90" />
                <Button Content="Accept" Command="{Binding AcceptMagCalCommand}" IsEnabled="{Binding CalRunning}" MinWidth="90" />
                <Button Content="Cancel" Command="{Binding CancelMagCalCommand}" IsEnabled="{Binding CalRunning}" MinWidth="90" />
              </StackPanel>

              <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="Mag 1" VerticalAlignment="Center" />
                <ProgressBar Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Prog1}" Height="18" />
                <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldlbl" Text="Mag 2" VerticalAlignment="Center" />
                <ProgressBar Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Prog2}" Height="18" />
                <TextBlock Grid.Row="2" Grid.Column="0" Classes="fieldlbl" Text="Mag 3" VerticalAlignment="Center" />
                <ProgressBar Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Prog3}" Height="18" />
              </Grid>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Classes="fieldlbl" Text="Fitness" VerticalAlignment="Center" />
                <ComboBox MinWidth="160" ItemsSource="{Binding FieldFitness.Options}" SelectedItem="{Binding FieldFitness.SelectedOption}" />
                <TextBlock Classes="fieldlbl" FontWeight="Bold" Text="Relax fitness if calibration fails" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>

            <TextBox
              Grid.Column="1"
              Width="240"
              MinHeight="150"
              Text="{Binding MagResult}"
              IsReadOnly="True"
              AcceptsReturn="True"
              TextWrapping="Wrap"
              VerticalContentAlignment="Top"
            />
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource MpInputBg}" CornerRadius="4" Padding="12" Margin="0,4,0,0">
        <StackPanel Spacing="8">
          <TextBlock Classes="fieldlbl" FontSize="15" Text="Quick Setup" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Pixhawk/PX4" Command="{Binding QuickPixhawkCommand}" />
            <Button Content="APM with On-Board Compass" Command="{Binding QuickApm25Command}" />
            <Button Content="APM with External Compass" Command="{Binding ApmExternalCommand}" />
          </StackPanel>
          <Button Content="Large Vehicle MagCal" Command="{Binding LargeVehicleMagCalCommand}" HorizontalAlignment="Left" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
