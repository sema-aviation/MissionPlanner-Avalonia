<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  mc:Ignorable="d"
  d:DesignWidth="900"
  d:DesignHeight="700"
  x:Class="MissionPlannerAvalonia.Views.GCSViews.ConfigurationView.ConfigPlannerView"
  x:DataType="cv:ConfigPlannerViewModel"
  Background="#434445"
>
  <ScrollViewer>
    <Grid
      Margin="16"
      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
      ColumnDefinitions="130,*"
    >
      <Grid.Styles>
        <Style Selector="TextBlock.lbl">
          <Setter Property="Foreground" Value="#D8D8D8" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="Margin" Value="0,6,10,6" />
        </Style>
        <Style Selector="ComboBox">
          <Setter Property="MinWidth" Value="200" />
        </Style>
      </Grid.Styles>

      <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Classes="pagetitle" Text="Planner Settings" />

      <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" Text="Speech" />
      <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10">
        <CheckBox Content="Enable Speech" IsChecked="{Binding EnableSpeech, Mode=TwoWay}" />
        <ComboBox ItemsSource="{Binding SpeechOptions}" SelectedItem="{Binding SpeechLevel}" />
      </StackPanel>

      <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" Text="UI Language" />
      <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="10">
        <ComboBox
          HorizontalAlignment="Left"
          ItemsSource="{Binding LanguageOptions}"
          SelectedItem="{Binding Language}"
        />
        <TextBlock Classes="lbl" Foreground="#E0A030" Text="{Binding LanguageNote}" />
      </StackPanel>

      <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" Text="Units" />
      <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <TextBlock Classes="lbl" Text="Dist" />
        <ComboBox
          MinWidth="110"
          ItemsSource="{Binding DistUnitsOptions}"
          SelectedItem="{Binding DistUnits}"
        />
        <TextBlock Classes="lbl" Text="Alt" />
        <ComboBox MinWidth="110" ItemsSource="{Binding DistUnitsOptions}" SelectedItem="{Binding AltUnits}" />
        <TextBlock Classes="lbl" Text="Speed" />
        <ComboBox
          MinWidth="170"
          ItemsSource="{Binding SpeedUnitsOptions}"
          SelectedItem="{Binding SpeedUnits}"
        />
      </StackPanel>

      <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" Text="Telemetry Rates" />
      <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="6">
        <TextBlock Classes="lbl" Text="Attitude" />
        <NumericUpDown Width="90" Value="{Binding TelemAttitude}" />
        <TextBlock Classes="lbl" Text="Position" />
        <NumericUpDown Width="90" Value="{Binding TelemPosition}" />
        <TextBlock Classes="lbl" Text="Mode" />
        <NumericUpDown Width="90" Value="{Binding TelemModeStatus}" />
        <TextBlock Classes="lbl" Text="RC" />
        <NumericUpDown Width="90" Value="{Binding TelemRc}" />
        <TextBlock Classes="lbl" Text="Sensor" />
        <NumericUpDown Width="90" Value="{Binding TelemSensor}" />
      </StackPanel>

      <TextBlock Grid.Row="5" Grid.Column="0" Classes="lbl" Text="Track Length" />
      <NumericUpDown
        Grid.Row="5"
        Grid.Column="1"
        Width="120"
        HorizontalAlignment="Left"
        Value="{Binding TrackLength}"
      />

      <TextBlock Grid.Row="6" Grid.Column="0" Classes="lbl" Text="Waypoints / HUD" />
      <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Spacing="14">
        <CheckBox Content="Load Waypoints on connect?" IsChecked="{Binding LoadWaypointsOnConnect, Mode=TwoWay}" />
        <CheckBox Content="Display in Flightdata" IsChecked="{Binding DisplayInFlightData, Mode=TwoWay}" />
        <CheckBox Content="Map follows plane" IsChecked="{Binding MapFollowPlane, Mode=TwoWay}" />
        <CheckBox Content="Enable HUD Overlay" IsChecked="{Binding EnableHudOverlay, Mode=TwoWay}" />
      </StackPanel>

      <TextBlock Grid.Row="7" Grid.Column="0" Classes="lbl" Text="Theme / Layout" />
      <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Theme}" />
        <ComboBox ItemsSource="{Binding LayoutOptions}" SelectedItem="{Binding Layout}" />
        <TextBlock Classes="lbl" Text="GCS ID" />
        <NumericUpDown Width="100" Value="{Binding GcsId}" />
      </StackPanel>

      <TextBlock Grid.Row="8" Grid.Column="0" Classes="lbl" Text="Aircraft Icon" />
      <WrapPanel Grid.Row="8" Grid.Column="1">
        <CheckBox Content="Display COG" IsChecked="{Binding DisplayCog, Mode=TwoWay}" Margin="0,0,12,0" />
        <CheckBox Content="Display Heading" IsChecked="{Binding DisplayHeading, Mode=TwoWay}" Margin="0,0,12,0" />
        <CheckBox Content="Display Nav Bearing" IsChecked="{Binding DisplayNavBearing, Mode=TwoWay}" Margin="0,0,12,0" />
        <CheckBox Content="Display Target" IsChecked="{Binding DisplayTarget, Mode=TwoWay}" Margin="0,0,12,0" />
        <CheckBox Content="Display ToolTip" IsChecked="{Binding DisplayTooltip, Mode=TwoWay}" Margin="0,0,12,0" />
      </WrapPanel>

      <TextBlock Grid.Row="9" Grid.Column="0" Classes="lbl" Text="Connect Reset" />
      <CheckBox
        Grid.Row="9"
        Grid.Column="1"
        Content="Reset on USB Connect (toggle DTR)"
        IsChecked="{Binding ResetOnUsbConnect, Mode=TwoWay}"
      />
    </Grid>
  </ScrollViewer>
</UserControl>
