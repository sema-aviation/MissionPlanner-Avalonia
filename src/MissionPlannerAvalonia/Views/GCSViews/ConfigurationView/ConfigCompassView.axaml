<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:cv="using:MissionPlannerAvalonia.ViewModels.GCSViews.ConfigurationView"
  xmlns:ctrl="using:MissionPlannerAvalonia.Controls"
  mc:Ignorable="d"
  d:DesignWidth="820"
  d:DesignHeight="720"
  x:Class="MissionPlannerAvalonia.Views.GCSViews.ConfigurationView.ConfigCompassView"
  x:DataType="cv:ConfigCompassViewModel"
  Background="#434445"
>
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="16">
      <TextBlock Grid.Row="0" Classes="pagetitle" Text="{Binding Title}" />

      <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,4,0,10">
        <Button Content="Refresh Params" Command="{Binding RefreshCommand}" />
        <TextBlock Text="{Binding Intro}" Classes="fieldlbl" VerticalAlignment="Center" TextWrapping="Wrap" />
      </StackPanel>

      <ItemsControl Grid.Row="2" ItemsSource="{Binding Fields}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="cv:ParamField">
            <Grid ColumnDefinitions="240,200,Auto,*" Margin="0,3">
              <TextBlock
                Grid.Column="0"
                Text="{Binding Label}"
                Classes="fieldlbl"
                ToolTip.Tip="{Binding Description}"
                TextWrapping="Wrap"
                Margin="0,0,8,0"
              />
              <ComboBox
                Grid.Column="1"
                IsVisible="{Binding IsCombo}"
                MinWidth="180"
                ItemsSource="{Binding Options}"
                SelectedItem="{Binding SelectedOption}"
              />
              <CheckBox Grid.Column="1" IsVisible="{Binding IsBool}" IsChecked="{Binding Checked}" />
              <NumericUpDown
                Grid.Column="1"
                IsVisible="{Binding IsNumeric}"
                MinWidth="180"
                Value="{Binding Value}"
                Minimum="{Binding Min}"
                Maximum="{Binding Max}"
                Increment="{Binding Increment}"
                FormatString="0.######"
              />
              <TextBlock Grid.Column="2" Text="{Binding Units}" Classes="fieldlbl" Margin="8,0" />
              <TextBlock Grid.Column="3" Text="{Binding Status}" Foreground="#94C11F" VerticalAlignment="Center" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Grid.Row="3" Background="#2D2D2D" CornerRadius="4" Padding="12" Margin="0,12,0,0">
        <StackPanel Spacing="8">
          <TextBlock Classes="fieldlbl" FontSize="15" Text="Compass Priority" />
          <TextBlock
            Classes="fieldlbl"
            TextWrapping="Wrap"
            Text="Detected compasses in priority order (COMPASS_PRIO1/2/3). Use Up/Down to reorder. A reboot is required for changes to take effect."
          />

          <DataGrid
            ItemsSource="{Binding Compasses}"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            GridLinesVisibility="All"
            CanUserResizeColumns="True"
            MinHeight="120"
            MaxHeight="220"
          >
            <DataGrid.Columns>
              <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="64" />
              <DataGridTextColumn Header="DevID" Binding="{Binding DevID}" Width="90" />
              <DataGridTextColumn Header="BusType" Binding="{Binding BusType}" Width="80" />
              <DataGridTextColumn Header="Bus" Binding="{Binding Bus}" Width="50" />
              <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="70" />
              <DataGridTextColumn Header="DevType" Binding="{Binding DevType}" Width="*" />
              <DataGridCheckBoxColumn Header="Missing" Binding="{Binding Missing}" Width="64" />
              <DataGridCheckBoxColumn Header="External" Binding="{Binding External}" Width="64" />
              <DataGridTextColumn Header="Orientation" Binding="{Binding Orientation}" Width="140" />
              <DataGridTemplateColumn Header="" Width="44">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="cv:CompassPrioRow">
                    <Button
                      Content="▲"
                      Padding="6,2"
                      Margin="2"
                      ToolTip.Tip="Move up"
                      Command="{Binding $parent[DataGrid].((cv:ConfigCompassViewModel)DataContext).MoveUpCommand}"
                      CommandParameter="{Binding}"
                    />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="" Width="44">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="cv:CompassPrioRow">
                    <Button
                      Content="▼"
                      Padding="6,2"
                      Margin="2"
                      ToolTip.Tip="Move down"
                      Command="{Binding $parent[DataGrid].((cv:ConfigCompassViewModel)DataContext).MoveDownCommand}"
                      CommandParameter="{Binding}"
                    />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <StackPanel Orientation="Horizontal" Spacing="16">
            <CheckBox Content="Use Compass 1" IsChecked="{Binding UseCompass1}" />
            <CheckBox Content="Use Compass 2" IsChecked="{Binding UseCompass2}" />
            <CheckBox Content="Use Compass 3" IsChecked="{Binding UseCompass3}" />
          </StackPanel>
          <CheckBox Content="Automatically learn offsets" IsChecked="{Binding LearnOffsets}" />

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Remove Missing" Command="{Binding RemoveMissingCommand}" />
            <Button Content="Reboot" Command="{Binding RebootCommand}" />
          </StackPanel>
          <TextBlock Text="{Binding CompassStatus}" Foreground="#E0A030" TextWrapping="Wrap" IsVisible="{Binding CompassStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
      </Border>

      <Grid Grid.Row="4" ColumnDefinitions="240,200,Auto" Margin="0,8,0,0">
        <TextBlock Grid.Column="0" Classes="fieldlbl" Text="Declination (deg)" VerticalAlignment="Center" />
        <NumericUpDown
          Grid.Column="1"
          MinWidth="180"
          Value="{Binding DeclinationDeg}"
          Increment="0.1"
          FormatString="0.###"
        />
        <Button Grid.Column="2" Content="Write Declination" Command="{Binding WriteDeclinationCommand}" Margin="8,0,0,0" />
      </Grid>

      <Border Grid.Row="5" Background="#2D2D2D" CornerRadius="4" Padding="12" Margin="0,12,0,0">
        <StackPanel Spacing="8">
          <TextBlock Classes="fieldlbl" FontSize="15" Text="Onboard Mag Calibration" />
          <TextBlock
            Classes="fieldlbl"
            TextWrapping="Wrap"
            Text="Press Start, then rotate the vehicle so every side points down towards the earth until each bar completes, then Accept. Cancel aborts."
          />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Start" Command="{Binding StartMagCalCommand}" MinWidth="90" />
            <Button Content="Accept" Command="{Binding AcceptMagCalCommand}" IsEnabled="{Binding CalRunning}" MinWidth="90" />
            <Button Content="Cancel" Command="{Binding CancelMagCalCommand}" IsEnabled="{Binding CalRunning}" MinWidth="90" />
          </StackPanel>

          <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="fieldlbl" Text="Compass 1" />
            <ProgressBar Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Prog1}" Height="18" />
            <TextBlock Grid.Row="1" Grid.Column="0" Classes="fieldlbl" Text="Compass 2" />
            <ProgressBar Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Prog2}" Height="18" />
            <TextBlock Grid.Row="2" Grid.Column="0" Classes="fieldlbl" Text="Compass 3" />
            <ProgressBar Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Prog3}" Height="18" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <TextBox
              Grid.Column="0"
              Text="{Binding MagResult}"
              IsReadOnly="True"
              AcceptsReturn="True"
              TextWrapping="Wrap"
              MinHeight="80"
            />
            <Border Grid.Column="1" Margin="10,0,0,0" BorderBrush="#555" BorderThickness="1" CornerRadius="3">
              <ctrl:MagCalSphere
                x:Name="MagSphere"
                Width="220"
                Height="220"
                ToolTip.Tip="Live mag-sample cloud (orthographic projection, not GL 3D). Drag to rotate."
              />
            </Border>
          </Grid>
        </StackPanel>
      </Border>

      <Border Grid.Row="6" Background="#2D2D2D" CornerRadius="4" Padding="12" Margin="0,12,0,0">
        <StackPanel Spacing="8">
          <TextBlock Classes="fieldlbl" FontSize="15" Text="Quick Configuration" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Pixhawk/Cube (onboard)" Command="{Binding QuickPixhawkCommand}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Classes="fieldlbl" Text="Large vehicle — current heading (deg true):" VerticalAlignment="Center" />
            <NumericUpDown MinWidth="120" Value="{Binding LargeVehicleHeading}" Increment="1" FormatString="0.#" />
            <Button Content="Calibrate (fixed yaw)" Command="{Binding LargeVehicleMagCalCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
