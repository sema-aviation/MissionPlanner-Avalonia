<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  xmlns:local="using:MissionPlannerAvalonia"
  xmlns:i="https://github.com/projektanker/icons.avalonia"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignWidth="1100"
  d:DesignHeight="700"
  x:Class="MissionPlannerAvalonia.Views.MainWindow"
  x:DataType="vm:MainWindowViewModel"
  Background="{DynamicResource MpBg}"
  Width="1280"
  Height="800"
  MinWidth="1120"
  MinHeight="720"
  Icon="/Assets/appicon.ico"
  Title="Mission Planner"
>
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.Resources>
    <local:StringEqualsConverter x:Key="Eq" />
  </Window.Resources>

  <DockPanel>
    <Border DockPanel.Dock="Top" Background="{DynamicResource MpBg}" Height="64">
      <Border.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Full Screen" Click="OnFullScreen" />
          <MenuItem Header="Readonly" Click="OnToggleReadonly" />
          <Separator />
          <MenuItem Header="Link Stats" Click="OnLinkStats" />
          <MenuItem Header="Connection Options" Click="OnConnectionOptions" />
          <MenuItem Header="Download Logs (MAVLink)" Click="OnDownloadLogs" />
          <MenuItem Header="Tlog Convert (KML/GPX/Matlab)" Click="OnMavlinkLogConvert" />
          <Separator />
          <MenuItem Header="Connection List (not ported)" IsEnabled="False" />
        </ContextMenu>
      </Border.ContextMenu>
      <Grid ColumnDefinitions="*,Auto,Auto">
        <ScrollViewer
          Grid.Column="0"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Disabled"
        >
          <StackPanel Orientation="Horizontal">
            <Button
              Classes="nav"
              Classes.active="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=DATA}"
              Command="{Binding NavigateCommand}"
              CommandParameter="DATA"
            >
              <StackPanel>
                <i:Icon Value="fa-solid fa-chart-line" FontSize="20" Foreground="#E0E0E0"
                        HorizontalAlignment="Center" />
                <TextBlock Classes="navtxt" Text="DATA" />
              </StackPanel>
            </Button>
            <Button
              Classes="nav"
              Classes.active="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=PLAN}"
              Command="{Binding NavigateCommand}"
              CommandParameter="PLAN"
            >
              <StackPanel>
                <i:Icon Value="fa-solid fa-map-location-dot" FontSize="20" Foreground="#E0E0E0"
                        HorizontalAlignment="Center" />
                <TextBlock Classes="navtxt" Text="PLAN" />
              </StackPanel>
            </Button>
            <Button
              Classes="nav"
              Classes.active="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=SETUP}"
              Command="{Binding NavigateCommand}"
              CommandParameter="SETUP"
            >
              <StackPanel>
                <i:Icon Value="fa-solid fa-screwdriver-wrench" FontSize="20" Foreground="#E0E0E0"
                        HorizontalAlignment="Center" />
                <TextBlock Classes="navtxt" Text="SETUP" />
              </StackPanel>
            </Button>
            <Button
              Classes="nav"
              Classes.active="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=CONFIG}"
              Command="{Binding NavigateCommand}"
              CommandParameter="CONFIG"
            >
              <StackPanel>
                <i:Icon Value="fa-solid fa-sliders" FontSize="20" Foreground="#E0E0E0"
                        HorizontalAlignment="Center" />
                <TextBlock Classes="navtxt" Text="CONFIG" />
              </StackPanel>
            </Button>
            <Button
              Classes="nav"
              Classes.active="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=SIMULATION}"
              Command="{Binding NavigateCommand}"
              CommandParameter="SIMULATION"
            >
              <StackPanel>
                <i:Icon Value="fa-solid fa-gamepad" FontSize="20" Foreground="#E0E0E0"
                        HorizontalAlignment="Center" />
                <TextBlock Classes="navtxt" Text="SIMULATION" />
              </StackPanel>
            </Button>
            <Button
              Classes="nav"
              Classes.active="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=HELP}"
              Command="{Binding NavigateCommand}"
              CommandParameter="HELP"
            >
              <StackPanel>
                <i:Icon Value="fa-solid fa-circle-question" FontSize="20" Foreground="#E0E0E0"
                        HorizontalAlignment="Center" />
                <TextBlock Classes="navtxt" Text="HELP" />
              </StackPanel>
            </Button>
          </StackPanel>
        </ScrollViewer>

        <Button
          Grid.Column="1"
          Command="{Binding OpenArduPilotSiteCommand}"
          Background="Transparent"
          BorderThickness="0"
          Padding="0"
          Cursor="Hand"
          ToolTip.Tip="ardupilot.org"
          VerticalAlignment="Center"
          Margin="16,0"
        >
          <TextBlock
            Text="ARDUPILOT"
            FontSize="26"
            FontWeight="Bold"
            FontStyle="Italic"
            Foreground="#F2C200"
          />
        </Button>

        <StackPanel
          Grid.Column="2"
          Orientation="Horizontal"
          VerticalAlignment="Center"
          Spacing="6"
          Margin="8,0,12,0"
          DataContext="{Binding Connection}"
        >
          <ComboBox
            Width="180"
            ItemsSource="{Binding Ports}"
            SelectedItem="{Binding SelectedPort}"
            PlaceholderText="serial port"
          />
          <ComboBox Width="90" ItemsSource="{Binding Bauds}" SelectedItem="{Binding SelectedBaud}" />
          <Button Content="⟳" Command="{Binding RefreshPortsCommand}" ToolTip.Tip="Refresh ports" />
          <Button Content="{Binding ConnectText}" Command="{Binding ToggleConnectCommand}" MinWidth="110" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid>
      <ContentControl Content="{Binding FlightData}"
        IsVisible="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=DATA}" />
      <ContentControl Content="{Binding FlightPlanner}"
        IsVisible="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=PLAN}" />
      <ContentControl Content="{Binding Setup}"
        IsVisible="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=SETUP}" />
      <ContentControl Content="{Binding Config}"
        IsVisible="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=CONFIG}" />
      <ContentControl Content="{Binding Simulation}"
        IsVisible="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=SIMULATION}" />
      <ContentControl Content="{Binding Help}"
        IsVisible="{Binding ActiveTab, Converter={StaticResource Eq}, ConverterParameter=HELP}" />
    </Grid>
  </DockPanel>
</Window>
