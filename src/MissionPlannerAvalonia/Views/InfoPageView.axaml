<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  mc:Ignorable="d"
  d:DesignWidth="800"
  d:DesignHeight="640"
  x:Class="MissionPlannerAvalonia.Views.InfoPageView"
  x:DataType="vm:InfoPageViewModel"
  Background="#434445"
>
  <StackPanel Margin="20" Spacing="8">
    <TextBlock Classes="pagetitle" Text="{Binding Title}" />
    <TextBlock
      Text="{Binding Note}"
      Foreground="#BBBBBB"
      TextWrapping="Wrap"
      MaxWidth="560"
      HorizontalAlignment="Left"
    />
  </StackPanel>
</UserControl>
