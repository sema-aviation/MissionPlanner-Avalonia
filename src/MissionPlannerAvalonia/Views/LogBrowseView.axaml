<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="using:MissionPlannerAvalonia.ViewModels"
  mc:Ignorable="d"
  d:DesignWidth="800"
  d:DesignHeight="500"
  x:Class="MissionPlannerAvalonia.Views.LogBrowseView"
  x:DataType="vm:LogBrowseViewModel"
  Background="#434445"
>
  <StackPanel Margin="12" Spacing="10">
    <Button x:Name="OpenBtn" Content="Open log…" />
    <TextBlock Text="{Binding Info}" Foreground="WhiteSmoke" />
  </StackPanel>
</UserControl>
