<Application
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="MissionPlannerAvalonia.App"
  xmlns:local="using:MissionPlannerAvalonia"
  RequestedThemeVariant="Dark"
>

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    <StyleInclude Source="avares://MissionPlannerAvalonia/Theme/MpTheme.axaml" />
  </Application.Styles>
</Application>
