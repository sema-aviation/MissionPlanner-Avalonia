<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <Color x:Key="MpBgColor">#262728</Color>
    <Color x:Key="MpControlBgColor">#434445</Color>
    <Color x:Key="MpTextColor">#FFFFFF</Color>
    <Color x:Key="MpButTop">#94C11F</Color>
    <Color x:Key="MpButBot">#CDE296</Color>
    <Color x:Key="MpButText">#405704</Color>
    <Color x:Key="MpBanner1">#405704</Color>
    <Color x:Key="MpBanner2">#94C11F</Color>

    <SolidColorBrush x:Key="MpBg" Color="{StaticResource MpBgColor}" />
    <SolidColorBrush x:Key="MpControlBg" Color="{StaticResource MpControlBgColor}" />
    <SolidColorBrush x:Key="MpText" Color="{StaticResource MpTextColor}" />
    <SolidColorBrush x:Key="MpButTextBrush" Color="{StaticResource MpButText}" />
    <LinearGradientBrush x:Key="MpButtonBrush" StartPoint="0%,0%" EndPoint="0%,100%">
      <GradientStop Offset="0" Color="{StaticResource MpButTop}" />
      <GradientStop Offset="1" Color="{StaticResource MpButBot}" />
    </LinearGradientBrush>
  </Styles.Resources>

  <Style Selector="Button">
    <Setter Property="Background" Value="{StaticResource MpButtonBrush}" />
    <Setter Property="Foreground" Value="{StaticResource MpButTextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#A6D62B" />
    <Setter Property="Foreground" Value="{StaticResource MpButTextBrush}" />
  </Style>

  <Style Selector="Button.nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#E0E0E0" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style Selector="Button.nav TextBlock.navicon">
    <Setter Property="FontSize" Value="20" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="#E0E0E0" />
  </Style>
  <Style Selector="Button.nav TextBlock.navtxt">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="#E0E0E0" />
  </Style>
  <Style Selector="Button.nav.active TextBlock">
    <Setter Property="Foreground" Value="#262728" />
  </Style>
  <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#3A3B3C" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
  <Style Selector="Button.nav.active">
    <Setter Property="Background" Value="#94C11F" />
    <Setter Property="Foreground" Value="#262728" />
  </Style>
  <Style Selector="Button.nav.active /template/ ContentPresenter">
    <Setter Property="Background" Value="#94C11F" />
  </Style>

  <Style Selector="TabControl">
    <Setter Property="Background" Value="{StaticResource MpControlBg}" />
  </Style>
  <Style Selector="TabItem">
    <Setter Property="Foreground" Value="#E0E0E0" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Padding" Value="5,2" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="MinHeight" Value="22" />
  </Style>
  <Style Selector="TabItem:selected">
    <Setter Property="Foreground" Value="#94C11F" />
  </Style>
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource MpText}" />
  </Style>
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="Black" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.side">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#E0E0E0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="FontWeight" Value="Normal" />
  </Style>
  <Style Selector="Button.side:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#94C11F" />
    <Setter Property="Foreground" Value="#262728" />
  </Style>

  <Style Selector="Button.backstage">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#E8E8E8" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style Selector="Button.backstage.sub">
    <Setter Property="Padding" Value="30,5" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="#C8C8C8" />
  </Style>
  <Style Selector="Button.backstage:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#2E2E2F" />
  </Style>
  <Style Selector="Button.backstage.active /template/ ContentPresenter">
    <Setter Property="Background" Value="#94C11F" />
    <Setter Property="TextElement.Foreground" Value="#1A1A1B" />
  </Style>

  <Style Selector="TextBlock.pagetitle">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#E8E8E8" />
    <Setter Property="Margin" Value="0,0,0,10" />
  </Style>
  <Style Selector="TextBlock.fieldlbl">
    <Setter Property="Foreground" Value="#D8D8D8" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.qv">
    <Setter Property="Background" Value="Black" />
    <Setter Property="BorderBrush" Value="#262728" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Margin" Value="1" />
    <Setter Property="Padding" Value="6" />
  </Style>
  <Style Selector="TextBlock.qval">
    <Setter Property="FontSize" Value="30" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.qlbl">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="#BBBBBB" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>
</Styles>
